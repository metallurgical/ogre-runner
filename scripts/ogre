#!/usr/bin/env bash
set -euo pipefail

OGRE_VERSION="1.4.19"
RUNTIME=".ai/.ogre"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGIN_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
TEMPLATE_DIR="$PLUGIN_DIR/templates"

usage() {
  cat <<USAGE
Ogre $OGRE_VERSION

Usage:
  ogre init
  ogre feature <issue-number|issue-url|issue-file> [--blocks 1,2,url,path] [--plan issue-107.md] [--planner claude|codex] [--model MODEL] [--reasoning LEVEL] [--browser-check]
  ogre feature --statement "free text description" [--name my-feature] [--blocks 1,2,url,path] [--plan NAME.md] [--planner claude|codex] [--model MODEL] [--reasoning LEVEL] [--browser-check]
                                   (--browser-check: opt-in - the generated plan tags steps needing real browser verification with [BROWSER-CHECK]. Default omits the tag entirely; the user verifies the feature themselves)
                                   (--planner/--model omitted: falls back to defaults.planner in .ai/.ogre/config.json, then claude/claude-sonnet-5)
  ogre add-blocker <issue> <blocker-number|url|path> [--force]
  ogre add-blocker <issue> --statement "free text blocker" [--name blocker-slug] [--force]
  ogre review-plan <issue-or-plan> [--reviewer claude|codex] [--model MODEL] [--reasoning LEVEL]
                                   (--reviewer/--model omitted: falls back to defaults.plan_reviewer in .ai/.ogre/config.json, then claude/claude-sonnet-5)
  ogre execute <issue-or-plan> [--executor codex|claude] [--model MODEL] [--reasoning LEVEL] [--mcp-config PATH] [--all] [--max-steps N] [--fresh|--resume] [--main|--background] [--yes] [--codex-unsandboxed-browser-check]
                                   (--executor/--model omitted: falls back to defaults.executor in .ai/.ogre/config.json, then claude/claude-sonnet-5)
                                   (--reasoning omitted: uses claude/codex's own default effort level - not forced by Ogre)
                                   (--mcp-config PATH: browser MCP for [BROWSER-CHECK] steps, so they run isolated; also settable as "browser_mcp" in .ai/.ogre/config.json)
                                   (--codex-unsandboxed-browser-check: opt-in - runs a codex [BROWSER-CHECK] step with --dangerously-bypass-approvals-and-sandbox instead of --sandbox workspace-write, because codex's sandbox otherwise blocks the browser subprocess entirely. Removes ALL confinement for that one step only, never on by default; also settable as "codex_unsandboxed_browser_check": true in .ai/.ogre/config.json)
  ogre execute --job <job-id> [same flags as above]              (same, addressed by job id)
  ogre execute <issue-or-plan> --task <task-id>                  (target one specific seeded step out of order)
  ogre execute <issue-or-plan> --step <n>                        (target step N, 1-based, out of order)
  ogre execute <issue-or-plan> --retry                           (re-run the lowest failed step, feeding the failed attempt's log tail into the fresh session)
  (default with no --task/--step: run the lowest-numbered pending step)
  Isolation mode (default: foreground, brand-new codex/claude session):
    (no flag)     foreground, new isolated session - main context untouched (incl. [BROWSER-CHECK]
                  steps, as long as the executor has a browser MCP; if none is detected, a
                  browser-check step auto-falls back to --main so it still completes, with a notice)
    --main        run inline in the current Claude Code session, no subprocess spawned (opt-in only)
    --background  same isolation as default, detached/non-blocking
  Granularity: default targets one step; --all chains through every remaining step, each session/subprocess
    capped at --max-steps items (default 3) and handing off to a fresh one at the cap or when it estimates
    ~50%+ context used, whichever comes first (so no single session grows unbounded).
  ogre stop [issue] [--all] [--archive] [--delete] [--list]     (stop the job: cascades to all its tasks)
  ogre stop --job <job-id> [--archive] [--delete] [--list]      (same, addressed by job id)
  ogre stop --task <task-id>                                    (stop ONE task only, job/siblings untouched)
  ogre config                                                   (show every config.json key ogre reads: dot path, current value/source, and the CLI flag that overrides it)
  ogre config --reset                                           (back up config.json to config.json.bak, then overwrite it with fresh-install defaults)
  ogre status [issue]
  ogre status --job <job-id>       (same as: ogre status <issue>, addressed by job id)
  ogre status --tasks [issue]
  ogre status --task <task-id>
  ogre task-list <job-id>          (every task under one job, one row each)
  ogre task-complete <task-id> [--status passed|failed] [--exit-code N] [--notes "..."]
                                   (mark a task done when it wasn't run via --run/--background;
                                    --notes records findings shown to every later session on the issue)

Concepts:
  job  = one feature/issue workflow (1:1 with an issue), id: job-<uuid>, lives in state/issue-<issue>.json
  task = one execute attempt under a job, id: task-<uuid>, ledger: state/tasks.json (shared across all jobs)

Each --run/--background task also records the native LLM CLI session id (session_id
field, "ogre status --task <id>"), so it can be resumed directly in its own TUI:
  claude --resume <session_id>
  codex resume <session_id>

Runtime:
  .ai/.ogre/
USAGE
}

log() { printf '%s\n' "$*"; }
err() { printf 'ERROR: %s\n' "$*" >&2; }

# write_default_config <path> - the fresh-install config.json, unconditionally
# overwritten to this. planner/plan_reviewer/executor here are read by
# config_default_role and used as the fallback whenever the matching
# --planner/--reviewer/--executor (and their --model) flag is omitted on the
# CLI - CLI flags always win. diff_reviewer has no consumer yet (no command
# uses that role) - it's reserved, not currently wired to anything.
write_default_config() {
  cat > "$1" <<'JSON'
{
  "defaults": {
    "planner": { "provider": "claude", "model": "claude-sonnet-5" },
    "plan_reviewer": { "provider": "claude", "model": "claude-sonnet-5" },
    "executor": { "provider": "claude", "model": "claude-sonnet-5" },
    "diff_reviewer": { "provider": "claude", "model": "claude-sonnet-5" }
  },
  "browser_mcp": null
}
JSON
}

ensure_runtime() {
  mkdir -p "$RUNTIME"/{issues,plans,reviews,logs,state,tmp,archive,prompts}
  if [ -d "$TEMPLATE_DIR" ]; then
    cp -f "$TEMPLATE_DIR"/*.md "$RUNTIME/prompts/" 2>/dev/null || true
  fi
  [ -f "$RUNTIME/state/tasks.json" ] || printf '[]' > "$RUNTIME/state/tasks.json"
  [ -f "$RUNTIME/config.json" ] || write_default_config "$RUNTIME/config.json"
}

now_iso() { date '+%Y-%m-%dT%H:%M:%S%z'; }

json_array() { python3 -c 'import json,sys; print(json.dumps(sys.argv[1:]))' "$@"; }

# json_field <file> <key> - print one top-level scalar field from a JSON file
# (empty string if the key is missing/null). Callers add 2>/dev/null when the
# file itself may be absent.
json_field() { python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get(sys.argv[2]) or '')" "$1" "$2"; }

# config_browser_mcp - the optional top-level "browser_mcp" field from
# .ai/.ogre/config.json (empty if unset/missing). A path (or JSON string)
# handed to `claude --mcp-config` so [BROWSER-CHECK] steps can reach a real
# browser from an isolated spawn. Empty is the normal case: spawns then rely
# on whatever MCP servers the environment already provides.
config_browser_mcp() {
  local cfg="$RUNTIME/config.json"
  [ -f "$cfg" ] || return 0
  python3 -c 'import json,sys
try: d = json.load(open(sys.argv[1]))
except Exception: sys.exit(0)
print(d.get("browser_mcp") or "")' "$cfg"
}

# config_codex_unsandboxed_browser_check - the optional top-level
# "codex_unsandboxed_browser_check" boolean field from .ai/.ogre/config.json.
# Prints "true"/"false". Off by default: opting in means a codex
# [BROWSER-CHECK] spawn runs with --dangerously-bypass-approvals-and-sandbox
# instead of --sandbox workspace-write, because codex's sandbox blocks the
# subprocess spawn a real browser needs (confirmed 2026-07-11 - not a tool
# approval issue, not a network issue, the sandbox itself denies launching
# Chromium). That flag removes ALL confinement (filesystem/shell/network) for
# that one spawn, not just the browser tool, so this is never assumed - the
# user explicitly accepts that trade for a live browser window under codex.
config_codex_unsandboxed_browser_check() {
  local cfg="$RUNTIME/config.json"
  [ -f "$cfg" ] || { printf 'false'; return 0; }
  python3 -c 'import json,sys
try: d = json.load(open(sys.argv[1]))
except Exception: print("false"); sys.exit(0)
print("true" if d.get("codex_unsandboxed_browser_check") else "false")' "$cfg"
}

# config_default_role <role> <field> - reads .defaults.<role>.<field> from
# .ai/.ogre/config.json (empty if unset/missing/no config file). role is one
# of planner|plan_reviewer|executor|diff_reviewer; field is provider|model.
# CLI flags always win over this - callers only consult it when the
# corresponding flag was not passed.
config_default_role() {
  local cfg="$RUNTIME/config.json" role="$1" field="$2"
  [ -f "$cfg" ] || return 0
  python3 -c 'import json,sys
try: d = json.load(open(sys.argv[1]))
except Exception: sys.exit(0)
print(((d.get("defaults") or {}).get(sys.argv[2]) or {}).get(sys.argv[3]) or "")' "$cfg" "$role" "$field"
}

gen_uuid() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  else
    python3 -c 'import uuid; print(uuid.uuid4())'
  fi
}

# Python prelude shared by every state-mutating snippet (each runs as its own
# interpreter process, so this can't be a normal python import). Two rules it
# enforces:
#   - lock_state(path): one exclusive flock per state dir (state/.lock), taken
#     BEFORE the first read, so concurrent read-modify-write cycles (e.g. a
#     --background task finishing while the user runs task-complete) serialize
#     instead of silently losing whichever update lands first.
#   - dump_json(obj, path): write to a sibling .tmp then rename, so a crash
#     mid-write can never leave a truncated/corrupt ledger behind. Readers
#     always see the old or the new file, never a partial one.
OGRE_PY_PRELUDE='
import json, os, fcntl
def lock_state(path):
    lk = open(os.path.join(os.path.dirname(path), ".lock"), "a")
    fcntl.flock(lk, fcntl.LOCK_EX)
    return lk
def dump_json(obj, path):
    tmp = path + ".tmp"
    with open(tmp, "w") as f:
        json.dump(obj, f, indent=2)
    os.replace(tmp, path)
'

# py_state [args...] <<PY - like `python3 - args <<PY` but with OGRE_PY_PRELUDE
# prepended to the program read from stdin.
py_state() {
  { printf '%s\n' "$OGRE_PY_PRELUDE"; cat; } | python3 - "$@"
}

# One job per feature/issue (1:1, id lives in state/issue-<issue>.json).
new_job_id() { echo "job-$(gen_uuid)"; }

# One task per execute attempt, many tasks per job. Shared ledger across all issues.
new_task_id() { echo "task-$(gen_uuid)"; }

tasks_path() { echo "$RUNTIME/state/tasks.json"; }

resolve_issue_by_job_id() {
  local job_id="$1"
  python3 -c '
import json, sys, glob
job_id = sys.argv[1]
for p in glob.glob(sys.argv[2]):
    try:
        d = json.load(open(p))
    except Exception:
        continue
    if d.get("job_id") == job_id:
        print(d.get("issue", ""))
        sys.exit(0)
' "$job_id" "$RUNTIME/state/issue-*.json"
}

# task_create <id> <issue> <type> <executor> <model> <mode> <freshness> <runner> <logpath> <status>
task_create() {
  py_state "$(tasks_path)" "$@" <<'PY'
import sys, datetime
path, tid, issue, ttype, executor, model, mode, freshness, runner, logpath, status = sys.argv[1:12]
_lk = lock_state(path)
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
now = datetime.datetime.now().astimezone().isoformat()
tasks.append({
    "id": tid, "issue": issue, "type": ttype, "executor": executor, "model": model or None,
    "mode": mode, "freshness": freshness, "runner": runner, "log_path": logpath,
    "status": status, "pid": None, "exit_code": None, "session_id": None,
    "notes": None,
    "created_at": now, "started_at": None, "ended_at": None, "updated_at": now,
})
dump_json(tasks, path)
PY
}

# task_update <id> <field=value> [field=value ...] - value "null" clears the field.
task_update() {
  local tid="$1"; shift
  py_state "$(tasks_path)" "$tid" "$@" <<'PY'
import sys, datetime
path, tid = sys.argv[1], sys.argv[2]
updates = dict(kv.split("=", 1) for kv in sys.argv[3:])
_lk = lock_state(path)
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
now = datetime.datetime.now().astimezone().isoformat()
for t in tasks:
    if t.get("id") == tid:
        for k, v in updates.items():
            if v == "null":
                t[k] = None
            elif k in ("exit_code", "pid") and v.lstrip("-").isdigit():
                t[k] = int(v)
            else:
                t[k] = v
        if updates.get("status") == "running" and not t.get("started_at"):
            t["started_at"] = now
        if updates.get("status") in ("passed", "failed", "stopped") and not t.get("ended_at"):
            t["ended_at"] = now
        t["updated_at"] = now
dump_json(tasks, path)
PY
}

task_get() {
  python3 - "$(tasks_path)" "$1" <<'PY'
import json, sys
path, tid = sys.argv[1], sys.argv[2]
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
for t in tasks:
    if t.get("id") == tid:
        print(json.dumps(t, indent=2))
        sys.exit(0)
print("null")
PY
}

task_field() {
  python3 - "$(tasks_path)" "$1" "$2" <<'PY'
import json, sys
path, tid, field = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
for t in tasks:
    if t.get("id") == tid:
        print(t.get(field) if t.get(field) is not None else "")
        sys.exit(0)
PY
}

# task_fields <tid> <field> [field...] - print the requested fields in order,
# one per line, from a SINGLE python invocation. Callers that need several
# fields off the same task (reap_task, stop_one_task, the execute step read)
# used to spend one `task_field` process per field; batching them here cuts
# a hot path like reap_all_tasks (run on every status/execute) from ~3-6
# python spawns per task down to one. Always prints exactly len(fields) lines
# (empty line for a missing/null field or unknown task), so callers can `read`
# a fixed number of values back. None of the fields read this way ever contain
# a newline, so a plain `read -r` per line round-trips them faithfully.
task_fields() {
  local tid="$1"; shift
  python3 - "$(tasks_path)" "$tid" "$@" <<'PY'
import json, sys
path, tid = sys.argv[1], sys.argv[2]
fields = sys.argv[3:]
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
t = next((x for x in tasks if x.get("id") == tid), None)
for f in fields:
    v = t.get(f) if t else None
    print("" if v is None else v)
PY
}

# repo_drift_block <plan-path> - markdown block of commits landed since the
# plan file was last written, plus any uncommitted working-tree changes.
# Injected into runner prompts so each executor session sees how the repo has
# moved since the plan's evidence was gathered (earlier steps, manual edits)
# instead of trusting stale assumptions - hallucinations sneak back in when a
# step trusts the plan's memory of files that later steps already changed.
# Anchor is the plan file's mtime (approximate but dependency-free); prints
# nothing outside a git repo or when nothing changed.
repo_drift_block() {
  local plan="$1"
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0
  local since commits dirty
  since="$(python3 -c 'import os,sys,datetime; print(datetime.datetime.fromtimestamp(os.path.getmtime(sys.argv[1])).strftime("%Y-%m-%dT%H:%M:%S"))' "$plan" 2>/dev/null)" || since=""
  commits=""
  [ -n "$since" ] && commits="$(git log --oneline --since="$since" -n 20 2>/dev/null || true)"
  dirty="$(git status --porcelain 2>/dev/null | grep -v '\.ai/' | head -20 || true)"
  [ -n "$commits" ] || [ -n "$dirty" ] || return 0
  echo "Repo drift since the plan was written (the plan's evidence may be stale - when the plan and current code disagree, trust current code and re-inspect):"
  echo
  if [ -n "$commits" ]; then
    echo "Commits landed after the plan:"
    echo '```'
    echo "$commits"
    echo '```'
  fi
  if [ -n "$dirty" ]; then
    echo "Uncommitted working-tree changes (likely earlier steps' output):"
    echo '```'
    echo "$dirty"
    echo '```'
  fi
}

# backfill_warning_block <state-path> - warning block for jobs whose ledger
# was backfilled from the plan (see ensure_state_from_plan): checkbox-derived
# "pending" statuses are unreliable there, so the executor must verify a step
# isn't already implemented before touching code. Prints nothing otherwise.
backfill_warning_block() {
  local spath="$1"
  [ -f "$spath" ] || return 0
  [ "$(json_field "$spath" backfilled 2>/dev/null || true)" = "True" ] || return 0
  cat <<'EOF'
Backfilled ledger warning: this job's state was reconstructed from the plan file (original ledger lost, or plan authored by hand), so "pending" is unreliable - the step's work may already exist in the code. FIRST check whether the target item is already implemented. If it is, validate it and mark it done (`task-complete --status passed`, with `--notes` saying it was pre-existing) WITHOUT re-implementing - re-editing finished work can damage it.
EOF
}

# retry_context_block <prev-log> <prev-exit> - failure context for an
# `execute --retry` runner: what the last attempt logged and how it exited.
# Feeding this to the fresh session turns a failure into an input instead of
# a dead end the human has to re-explain from the log by hand.
retry_context_block() {
  local prev_log="$1" prev_exit="$2"
  echo "Previous attempt for this step FAILED${prev_exit:+ (exit code $prev_exit)}. Diagnose why before re-implementing - do not repeat the same approach blindly. The working tree may still contain partial changes from that attempt; inspect them and finish or revert them as part of this step."
  if [ -n "$prev_log" ] && [ -f "$prev_log" ]; then
    echo
    echo "Log tail from the failed attempt:"
    echo '```'
    tail -n 40 "$prev_log" 2>/dev/null || true
    echo '```'
  fi
}

# reap_task <id> - if a background task's sentinel exit file has appeared,
# resolve it from "running" to "passed"/"failed" and record the exit code.
# Reaching this still-"running" means the subprocess's own task-complete
# call never landed, so (like finalize_link_status) fail closed on exit
# code alone rather than guessing "passed" from a bare rc==0.
reap_task() {
  local tid="$1"
  # One batched read for every field this function might need, instead of a
  # fresh python spawn per field. The common case (task still running, no exit
  # sentinel yet, pid alive) now costs one spawn here instead of three.
  local issue status executor session_id codex_logpath pid exitfile
  { read -r issue; read -r status; read -r executor; read -r session_id; read -r codex_logpath; read -r pid; } \
    < <(task_fields "$tid" issue status executor session_id log_path pid)
  [ -n "$issue" ] || return 0
  [ "$status" = "running" ] || return 0
  exitfile="$RUNTIME/tmp/issue-$issue/$tid.exit"
  if [ -f "$exitfile" ]; then
    local code
    code="$(cat "$exitfile")"
    task_update "$tid" "status=failed" "exit_code=$code"
    if [ "$executor" = "codex" ] && [ -z "$session_id" ]; then
      local codex_sid
      codex_sid="$(grep -m1 '^session id: ' "$codex_logpath" 2>/dev/null | sed 's/^session id: //')"
      [ -n "$codex_sid" ] && task_update "$tid" "session_id=$codex_sid"
    fi
    rm -f "$exitfile" "$RUNTIME/tmp/issue-$issue/$tid.pid"
    sync_state_from_plan "$issue"
    return 0
  fi
  # No exit sentinel. The background wrapper always writes one before exiting,
  # so a recorded pid that is no longer alive means the process died without
  # reporting (kill -9, reboot, crash). Fail the task instead of leaving it
  # "running" in the ledger forever - a stuck "running" blocks re-execution
  # and makes status lie about in-flight work.
  if [ -n "$pid" ] && ! kill -0 "$pid" 2>/dev/null; then
    task_update "$tid" "status=failed"
    rm -f "$RUNTIME/tmp/issue-$issue/$tid.pid"
    sync_state_from_plan "$issue"
    log "Task $tid was running but its process (pid $pid) is gone - marked failed."
  fi
}

reap_all_tasks() {
  python3 -c '
import json
try:
    tasks = json.load(open("'"$(tasks_path)"'"))
except Exception:
    tasks = []
for t in tasks:
    if t.get("status") == "running":
        print(t["id"])
' | while IFS= read -r tid; do
    [ -n "$tid" ] && reap_task "$tid"
  done
}

# maybe_resume_stalled_chain <issue> - a `--all --background` chain link is
# supposed to keep spawning fresh sessions on its own (should_continue_chain)
# until nothing pending is left. Observed in the wild: the driver subshell
# can die outright between one link finishing and the next one starting -
# no crash trace, no exit sentinel, just gone - leaving pending steps with no
# task running and nothing to resume it. Call this after reap_all_tasks +
# sync_state_from_plan (both call sites already run in that order) so a dead
# pid has already been reaped into a terminal ledger status by the time this
# runs. Idempotent: the resumed chain's own new task immediately shows up as
# "running" with a live pid, so a status call landing moments later sees that
# and does nothing - no risk of double-launching a second chain on top.
maybe_resume_stalled_chain() {
  local issue="$1"
  local spath
  spath="$(state_path "$issue")"
  [ -f "$spath" ] || return 0
  local status pending_left job_id
  { read -r status; read -r pending_left; read -r job_id; } < <(python3 -c '
import json
try:
    d = json.load(open("'"$spath"'"))
except Exception:
    d = {}
print(d.get("status") or "")
print(len(d.get("pending_steps") or []))
print(d.get("job_id") or "")
')
  case "$status" in
    stopped|completed|planning|"") return 0 ;;
  esac
  [ "${pending_left:-0}" -gt 0 ] || return 0
  [ -n "$job_id" ] || return 0

  # Most recently created `mode=all` (chained) task for this issue - that's
  # the one whose death (if any) means the chain stopped without finishing.
  # A single-step (non-chained) `execute` never self-resumes and was never
  # supposed to, so this only ever acts on mode=all tasks.
  local last_tid last_status last_pid executor model
  { read -r last_tid; read -r last_status; read -r last_pid; read -r executor; read -r model; } < <(python3 -c '
import json
try:
    tasks = json.load(open("'"$(tasks_path)"'"))
except Exception:
    tasks = []
cand = [t for t in tasks if t.get("issue") == "'"$issue"'" and t.get("mode") == "all"]
cand.sort(key=lambda t: t.get("created_at") or "")
if cand:
    t = cand[-1]
    for f in ("id", "status", "pid", "executor", "model"):
        v = t.get(f)
        print("" if v is None else v)
else:
    print(""); print(""); print(""); print(""); print("")
')
  [ -n "$last_tid" ] || return 0
  [ "$last_status" != "running" ] || return 0
  # Belt and suspenders: if the pid is somehow still alive despite a
  # terminal ledger status, it's mid-finalization, not stalled - don't race it.
  [ -z "$last_pid" ] || ! kill -0 "$last_pid" 2>/dev/null || return 0

  log ""
  log "Chain for issue $issue looks stalled: $pending_left step(s) still pending, last chain task ($last_tid) is '$last_status' with no live process behind it. Auto-resuming a fresh --all --background chain."
  local -a resume_args=(execute --job "$job_id" --all --background)
  [ -n "$executor" ] && resume_args+=(--executor "$executor")
  [ -n "$model" ] && resume_args+=(--model "$model")
  "$SCRIPT_DIR/ogre" "${resume_args[@]}" \
    || err "Auto-resume for issue $issue failed to start - resume it yourself: $SCRIPT_DIR/ogre execute --job $job_id --all --background"
}

tasks_list() {
  local issue_filter="${1:-}"
  reap_all_tasks
  python3 -c '
import json, sys
path, issue_filter = sys.argv[1], sys.argv[2]
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
for t in tasks:
    if issue_filter and str(t.get("issue")) != issue_filter:
        continue
    print("{}  issue={}  status={}  executor={}  started={}  ended={}  log={}".format(t.get("id"), t.get("issue"), t.get("status"), t.get("executor"), t.get("started_at"), t.get("ended_at"), t.get("log_path")))
' "$(tasks_path)" "$issue_filter"
}

gh_view_issue() {
  local input="$1" out="$2"
  # `gh issue view --comments` returns empty stdout when the issue has zero
  # comments (gh quirk) - fall back to plain view (full body, no comments) so
  # we never silently write an empty issue file. Both calls are allowed to
  # fail (wrong host, no auth, no access, script not run inside the repo) -
  # caller checks the return value and falls back to a placeholder instead
  # of crashing under `set -e`.
  gh issue view "$input" --comments > "$out" 2>/dev/null || true
  if [ ! -s "$out" ]; then
    gh issue view "$input" > "$out" 2>/dev/null || true
  fi
  [ -s "$out" ]
}

# Best-effort fetch for non-GitHub issue/page links (GitLab, self-hosted
# GitLab, Bitbucket, Jira, or any other web page): no API client, just GET
# the page and strip HTML down to readable text. Works for public pages
# that render content server-side; private/JS-only pages will come back
# empty and the caller falls back to a placeholder.
fetch_generic_url_text() {
  local url="$1" out="$2"
  command -v curl >/dev/null 2>&1 || return 1
  local html
  html="$(curl -fsSL --max-time 15 "$url" 2>/dev/null)" || return 1
  [ -n "$html" ] || return 1
  printf '%s' "$html" | python3 -c '
import sys, re, html as htmllib
data = sys.stdin.read()
data = re.sub(r"(?is)<(script|style|noscript).*?</\1>", "", data)
data = re.sub(r"(?s)<!--.*?-->", "", data)
text = re.sub(r"(?s)<[^>]+>", "\n", data)
text = htmllib.unescape(text)
lines = [ln.strip() for ln in text.splitlines()]
lines = [ln for ln in lines if ln]
print("\n".join(lines))
' > "$out" 2>/dev/null || return 1
  [ -s "$out" ]
}

# Derive a short readable slug from freeform --statement text (first few
# words, lowercased, non-alnum -> "-") so the issue's .md files are
# recognizable at a glance instead of an opaque "adhoc-<timestamp>".
slugify_statement() {
  local text="$1"
  local words suffix
  words="$(echo "$text" \
    | awk '{for (i=1; i<=4 && i<=NF; i++) printf "%s ", $i}' \
    | tr '[:upper:]' '[:lower:]' \
    | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' \
    | cut -c1-24 \
    | sed -E 's/-+$//')"
  suffix="$(gen_uuid | tr -d '-' | cut -c1-8)"
  if [ -n "$words" ]; then
    echo "${words}-${suffix}"
  else
    echo "$suffix"
  fi
}

# validate_slug <value> <flag-name-for-error> - a user-supplied --name value
# (issue slug or blocker slug) becomes part of MANY file paths across the
# runtime (state/, issues/, plans/, logs/, tmp/, archive/) and is embedded
# directly into generated JSON and a couple of python heredocs. An
# unrestricted value could path-traverse outside .ai/.ogre/ (e.g.
# `--name ../../../etc/cron.d/evil`), corrupt state.json (a `"` breaks the
# hand-written JSON heredoc in write_state), or - for the two `<<PY`
# (unquoted) heredocs that splice a state path directly into python source -
# break out of the string literal into arbitrary python. Restricting to a
# plain slug charset closes all three at the source. Exits 1 on failure.
validate_slug() {
  local value="$1" flag="$2"
  [[ "$value" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]] && return 0
  err "Invalid $flag: '$value' - must start with a letter/digit and contain only letters, digits, '-', '_' (no slashes, dots, quotes, or spaces)."
  exit 1
}

slug_from_issue() {
  local input="$1"
  if [[ "$input" =~ ^[0-9]+$ ]]; then
    echo "$input"
    return
  fi
  if [[ "$input" =~ /issues/([0-9]+) ]]; then
    echo "${BASH_REMATCH[1]}"
    return
  fi
  local base
  base="$(basename "$input")"
  base="${base#issue-}"
  base="${base%.*}"
  if [[ "$base" =~ ^[0-9]+$ ]]; then
    echo "$base"
    return
  fi
  # Custom (non-numeric) slugs from `--name`, e.g. `demo` or `adhoc-<timestamp>`.
  if [[ "$base" =~ ^[A-Za-z0-9][A-Za-z0-9_-]*$ ]]; then
    echo "$base"
    return
  fi
  if [[ "$base" =~ ([0-9]+) ]]; then
    echo "${BASH_REMATCH[1]}"
    return
  fi
  echo "unknown"
}

issue_file_path() {
  local input="$1"
  local n
  n="$(slug_from_issue "$input")"
  echo "$RUNTIME/issues/issue-$n.md"
}

# .docx is a zip of XML, not plain text - `cp` would dump binary garbage into
# the issue .md file. zipfile/re/html are stdlib, so no extra dependency
# beyond the python3 this script already requires elsewhere.
fetch_docx_text() {
  local input="$1" out="$2"
  python3 -c '
import sys, zipfile, re, html
path = sys.argv[1]
try:
    with zipfile.ZipFile(path) as z:
        xml = z.read("word/document.xml").decode("utf-8", "ignore")
except Exception:
    sys.exit(1)
xml = re.sub(r"</w:p>", "\n", xml)
xml = re.sub(r"<w:tab/?>", "\t", xml)
text = re.sub(r"<[^>]+>", "", xml)
text = html.unescape(text)
print("\n".join(ln.rstrip() for ln in text.splitlines()))
' "$input" > "$out" 2>/dev/null
  [ -s "$out" ]
}

fetch_issue() {
  local input="$1"
  local out="$2"
  mkdir -p "$(dirname "$out")"

  if [ -f "$input" ]; then
    local ext
    ext="$(printf '%s' "$input" | sed -E 's/.*\.//' | tr '[:upper:]' '[:lower:]')"
    if [ "$ext" = "docx" ]; then
      if fetch_docx_text "$input" "$out"; then
        log "Extracted text from docx: $input -> $out"
      else
        cp "$input" "$out"
        log "Could not parse docx (unzip/XML read failed) - fell back to raw copy, likely unusable as-is: $input -> $out"
      fi
    else
      # .txt, .md, and anything else already-plain-text: copy verbatim.
      cp "$input" "$out"
      log "Copied issue file: $input -> $out"
    fi
    return
  fi

  if [[ "$input" =~ ^https?:// ]]; then
    if [[ "$input" =~ ^https?://(www\.)?github\.com/ ]] && command -v gh >/dev/null 2>&1; then
      log "Fetching GitHub issue URL: $input"
      if gh_view_issue "$input" "$out"; then
        return
      fi
      log "gh could not fetch $input (no access, not authenticated, or bad URL) - falling back to a generic page fetch"
    fi
    # Non-GitHub link (GitLab, self-hosted GitLab, Bitbucket, Jira, any other
    # page), or GitHub link that gh couldn't fetch: no API client for these,
    # just fetch the page and strip HTML down to text.
    log "Fetching page content: $input"
    if fetch_generic_url_text "$input" "$out.body"; then
      {
        echo "# Issue Source"
        echo
        echo "Original input: $input"
        echo
        echo "Fetched generically (non-GitHub link, or GitHub link \`gh\` could not read) - this is raw extracted page text, not a structured issue. Review for accuracy before planning."
        echo
        echo "---"
        echo
        cat "$out.body"
      } > "$out"
      rm -f "$out.body"
      log "Wrote fetched page text: $out"
    else
      cat > "$out" <<EOF2
# Issue Source

Could not fetch automatically: $input

This is either a non-GitHub link the page could not be reached (network, auth-walled/private, or JS-rendered content with nothing in the raw HTML).

Paste the issue/problem/feature statement content here before planning.
EOF2
      log "Created placeholder issue file: $out"
    fi
    return
  fi

  if [[ "$input" =~ ^[0-9]+$ ]]; then
    # Bare issue numbers are GitHub-only (resolved via gh + the project's git
    # remote) - GitLab/Bitbucket/etc have no equivalent short form here, paste
    # the full issue URL instead for those.
    if command -v gh >/dev/null 2>&1; then
      log "Fetching GitHub issue #$input"
      if gh_view_issue "$input" "$out"; then
        return
      fi
      log "gh could not fetch issue #$input (not a GitHub repo here, no gh auth, or no access)"
    fi
    cat > "$out" <<EOF2
# GitHub Issue #$input

Could not fetch automatically (gh CLI missing, this directory isn't a GitHub repo, not authenticated, or no access to the issue).

Bare issue numbers only work for GitHub. For GitLab/Bitbucket/self-hosted/etc, paste the full issue URL instead.

Paste the issue content here before planning.
EOF2
    log "Created placeholder issue file: $out"
    return
  fi

  cat > "$out" <<EOF2
# Issue Input

Original input: $input

Ogre could not identify this as a file path, GitHub issue URL, or issue number.
Paste the issue content here before planning.
EOF2
  log "Created placeholder issue file: $out"
}

# Prepend a user-supplied remark to a blocker's issue file so the remark
# (e.g. "PR merged", "under review") travels inline with the content the
# planner reads. No-op when the remark is empty or the file is missing.
# fetch_issue always rewrites the file fresh before this runs, so re-adding a
# blocker can't stack duplicate remark headers.
prepend_blocker_remark() {
  local bpath="$1" remark="$2"
  [ -n "$remark" ] || return 0
  [ -f "$bpath" ] || return 0
  local tmp
  tmp="$(mktemp)"
  {
    printf '> **Blocker remark (user-provided):** %s\n\n' "$remark"
    cat "$bpath"
  } > "$tmp"
  mv "$tmp" "$bpath"
}

# Emit a JSON object mapping blocker path -> remark from alternating
# path/remark argv pairs. Paths whose remark is empty are omitted, so a
# blocker added without --remarks leaves no key behind.
blocker_remarks_json() {
  python3 -c '
import json, sys
a = sys.argv[1:]
d = {}
for i in range(0, len(a) - 1, 2):
    p, r = a[i], a[i + 1]
    if r:
        d[p] = r
print(json.dumps(d))
' "$@"
}

state_path() {
  local issue="$1"
  echo "$RUNTIME/state/issue-$issue.json"
}

# Living knowledge base for one issue: a markdown file every execute step
# reads first (instant orientation) and updates last (findings survive the
# session that found them). Persistent on disk like the rest of state/.
knowledge_path() {
  local issue="$1"
  echo "$RUNTIME/state/issue-$issue-knowledge.md"
}

# Soft cap: over this many lines, the file is warned about (never blocked) so
# the next step distils it before it rots context.
KNOWLEDGE_SOFT_LINE_CAP=200

# Create the knowledge file from the template skeleton if it doesn't exist
# yet. Copied verbatim except the `# Knowledge — <issue>` heading gets the
# real issue. No-op if already present (never clobber accumulated knowledge)
# or if the template is missing (older checkout).
seed_knowledge() {
  local issue="$1"
  local kpath tmpl
  kpath="$(knowledge_path "$issue")"
  [ -f "$kpath" ] && return 0
  tmpl="$RUNTIME/prompts/knowledge-base.md"
  [ -f "$tmpl" ] || tmpl="$TEMPLATE_DIR/knowledge-base.md"
  [ -f "$tmpl" ] || return 0
  mkdir -p "$(dirname "$kpath")"
  sed "s/# Knowledge — <issue>/# Knowledge — $issue/" "$tmpl" > "$kpath.tmp" && mv "$kpath.tmp" "$kpath"
}

# True if the knowledge file has any real content - i.e. at least one line
# that isn't an HTML comment, a heading, the placeholder "(none recorded
# yet)", or blank. A freshly-seeded, all-placeholder file counts as empty, so
# knowledge_block stays silent until a step has actually written something.
knowledge_has_content() {
  local issue="$1" kpath
  kpath="$(knowledge_path "$issue")"
  [ -f "$kpath" ] || return 1
  python3 - "$kpath" <<'PY'
import sys
path = sys.argv[1]
in_comment = False
for raw in open(path):
    line = raw.strip()
    if not line:
        continue
    if in_comment:
        if "-->" in line:
            in_comment = False
        continue
    if line.startswith("<!--"):
        if "-->" not in line:
            in_comment = True
        continue
    if line.startswith("#") or line.startswith("<!"):
        continue
    if line == "- (none recorded yet)" or line == "(none recorded yet)":
        continue
    sys.exit(0)  # found real content
sys.exit(1)
PY
}

# knowledge_block <issue> - the knowledge file's contents wrapped in a lead-in,
# for injection into a runner prompt. Prints nothing until a step has recorded
# something real, so early runners aren't padded with an empty skeleton.
knowledge_block() {
  local issue="$1" kpath
  kpath="$(knowledge_path "$issue")"
  knowledge_has_content "$issue" || return 0
  echo "Knowledge from earlier steps on this issue - read this before touching code. It records what previous steps already learned (conventions, verified signatures, validation commands, gotchas, and what each step did), so you don't have to re-derive it. It's a head-start, not a cage: still read real code when the task needs it, and if anything here disagrees with the actual code, the code wins - fix the stale line as you go."
  echo
  cat "$kpath"
}

# Warn (never fail) when a knowledge file has grown past the soft cap, so
# unbounded growth is visible and the next step knows to distil it.
warn_if_knowledge_bloated() {
  local issue="$1" kpath lines
  kpath="$(knowledge_path "$issue")"
  [ -f "$kpath" ] || return 0
  lines="$(wc -l < "$kpath" | tr -d ' ')"
  if [ "${lines:-0}" -gt "$KNOWLEDGE_SOFT_LINE_CAP" ]; then
    log "WARNING: knowledge base for issue $issue is $lines lines - over the ~$KNOWLEDGE_SOFT_LINE_CAP soft cap. The next step should distil it (fold Step Log facts up into the durable sections, drop stale lines) before it rots context."
  fi
}

write_state() {
  local issue="$1" status="$2" plan="$3" planner="$4" planner_model="$5" reviewer="$6" reviewer_model="$7" executor="$8" executor_model="$9"
  local blocker_paths_json="${10:-[]}"
  local blocker_remarks_json="${11:-}"
  [ -n "$blocker_remarks_json" ] || blocker_remarks_json="{}"
  local path job_id
  path="$(state_path "$issue")"
  job_id="$(new_job_id)"
  mkdir -p "$(dirname "$path")"
  # Built via json.dumps (argv-passed, never string-interpolated into JSON
  # text) rather than a hand-rolled heredoc, so a quote/backslash in any
  # user-supplied field (--model, --plan, --planner, --executor) can never
  # corrupt the file - the json module escapes it correctly no matter what.
  py_state "$path" "$issue" "$job_id" "$status" "$plan" "$planner" "$planner_model" \
    "$reviewer" "$reviewer_model" "$executor" "$executor_model" \
    "$blocker_paths_json" "$blocker_remarks_json" "$(now_iso)" <<'PY'
import sys
(path, issue, job_id, status, plan, planner, planner_model,
 reviewer, reviewer_model, executor, executor_model,
 blocker_paths_json, blocker_remarks_json, created_at) = sys.argv[1:15]
d = {
    "issue": issue,
    "job_id": job_id,
    "status": status,
    "plan_path": plan,
    "planner": {"provider": planner, "model": planner_model},
    "reviewer": {"provider": reviewer, "model": reviewer_model},
    "executor": {"provider": executor, "model": executor_model},
    "blocker_paths": json.loads(blocker_paths_json),
    "blocker_remarks": json.loads(blocker_remarks_json),
    "completed_steps": [],
    "current_step": None,
    "total_steps": None,
    "active_task": None,
    "last_log": None,
    "last_validation": None,
    "created_at": created_at,
    "updated_at": created_at,
}
dump_json(d, path)
PY
  seed_knowledge "$issue"
  log "State written: $path (job_id: $job_id)"
}

# update_role_state <issue> <role> <provider> <model> - persist the actually
# resolved (flag-wins-else-config) reviewer/executor into state.json every
# time review-plan/execute really runs. write_state only fires once, at
# `ogre feature` time, seeding a guess for reviewer/executor before either has
# ever been invoked - if left untouched after that, state.json silently drifts
# from reality the moment a later --reviewer/--executor flag or an updated
# config.json default picks something else, and `ogre status` then reports a
# provider that never actually ran. No-ops if state.json doesn't exist yet.
update_role_state() {
  local issue="$1" role="$2" provider="$3" model="$4" spath
  spath="$(state_path "$issue")"
  [ -f "$spath" ] || return 0
  py_state "$spath" "$role" "$provider" "$model" "$(now_iso)" <<'PY'
import sys
spath, role, provider, model, updated_at = sys.argv[1:6]
_lk = lock_state(spath)
d = json.load(open(spath))
d[role] = {"provider": provider, "model": model}
d["updated_at"] = updated_at
dump_json(d, spath)
PY
}

# True (exit 0) if execution appears to have already started for this issue -
# blockers must not be added after that point since the checklist/state is
# already in motion against the old blocker list.
execution_started() {
  local issue="$1"
  local logdir="$RUNTIME/logs/issue-$issue"
  compgen -G "$logdir/execute-*.log" >/dev/null 2>&1 && return 0
  local spath
  spath="$(state_path "$issue")"
  if [ -f "$spath" ]; then
    python3 - "$spath" <<'PY' 2>/dev/null
import json, sys
d = json.load(open(sys.argv[1]))
ok = d.get('status') == 'executing' or len(d.get('completed_steps') or []) > 0 or d.get('current_step') is not None
sys.exit(0 if ok else 1)
PY
    return $?
  fi
  return 1
}

# A plan can exist with no state.json behind it - e.g. authored by hand
# instead of via `ogre feature`, or the state file was lost/deleted while the
# plan survived. Back-fill a fresh state record from the plan so the rest of
# the pipeline (status/execute/task-list) doesn't have to treat "plan exists,
# state doesn't" as a dead end.
ensure_state_from_plan() {
  local issue="$1"
  local spath plan
  spath="$(state_path "$issue")"
  [ -f "$spath" ] && return 0
  plan="$RUNTIME/plans/issue-$issue.md"
  [ -f "$plan" ] || return 1
  write_state "$issue" "planning" "$plan" "claude" "claude-sonnet-5" "claude" "claude-sonnet-5" "codex" "gpt-5.6-sol" "[]"
  # Flag the record: a backfilled ledger only knows what the plan's checkboxes
  # say, so its "pending" statuses are unreliable - work may already exist in
  # the code from before the state was lost. Runner prompts read this flag and
  # tell the executor to verify before re-implementing (re-editing finished
  # work can damage it).
  py_state "$spath" <<'PY'
import sys, datetime
p = sys.argv[1]
_lk = lock_state(p)
d = json.load(open(p))
d['backfilled'] = True
d['updated_at'] = datetime.datetime.now().astimezone().isoformat()
dump_json(d, p)
PY
  log "No ledger state for issue $issue but plan exists at $plan - backfilling state (plan created outside 'ogre feature'?)."
}

# Codex/Claude edit the plan's markdown checklist directly, they never touch
# state.json. Re-derive completed_steps/current_step from the plan file's
# "## 6. Execution Order" checklist so state.json doesn't silently drift out
# of sync with what the executor actually did.
sync_state_from_plan() {
  local issue="$1"
  local spath plan
  ensure_state_from_plan "$issue" || return 0
  spath="$(state_path "$issue")"
  [ -f "$spath" ] || return 0
  plan="$(json_field "$spath" plan_path 2>/dev/null)"
  [ -n "$plan" ] && [ -f "$plan" ] || return 0
  py_state "$spath" "$plan" "$issue" "$(tasks_path)" <<'PY' 2>/dev/null || true
import re, sys, datetime, uuid
spath, plan_path, issue, tasks_path = sys.argv[1:5]
# One lock covers both files below (same state dir).
_lk = lock_state(spath)
text = open(plan_path).read()
m = re.search(r"##\s*6\.\s*Execution Order(.*?)(\n##\s|\Z)", text, re.S)
section = m.group(1) if m else text
# Marker capture is deliberately lenient ([^\]]* not just " |x|X"): an
# executor sometimes invents a non-standard marker on failure (e.g.
# "[FAILED]") despite being told not to. Strict matching would silently drop
# that whole line from `items` - not "pending", just gone, breaking chain
# continuation and any auto-fix logic that depends on seeing it. Any marker
# other than exactly "x"/"X" is treated as not-done (see is_done below), so
# the item stays visible and pending instead of vanishing.
items = re.findall(r"^\s*[-*]\s*\[([^\]]*)\]\s*(.+)$", section, re.M)

# Ad-hoc [AUTO-FIX n/cap fp:<hash>] lines (see synthesize_auto_fix_step) are
# real checklist items for execution purposes, but they didn't exist when the
# user reviewed/approved the plan - counting them in total_steps makes a
# 4-step plan suddenly read as "6 steps" the moment a browser-check fails,
# which reads as the plan itself changing rather than an internal retry. Keep
# them working exactly the same for execution/ordering (step_index is
# untouched), just don't let them inflate the step count the user sees.
def is_auto_fix(raw_text):
    return bool(re.match(r"^\[AUTO-FIX \d+/\d+ fp:", raw_text.strip()))

try:
    tasks = json.load(open(tasks_path))
except Exception:
    tasks = []
issue_tasks = [t for t in tasks if t.get("issue") == issue]
by_text = {t.get("step"): t for t in issue_tasks if t.get("step")}

# A step counts as done if its checkbox is ticked OR its matched ledger task
# already recorded "passed" - the executor sometimes finishes the real work
# and calls task-complete but forgets to tick the box (or vice versa), and
# either signal alone is authoritative. This is only safe because a ledger
# "passed" can no longer come from an optimistic exit-code guess (see
# finalize_link_status/reap_task) - it always reflects an explicit call.
def is_done(marker, raw_text):
    if marker.lower() == "x":
        return True
    t = by_text.get(raw_text.strip())
    return bool(t and t.get("status") == "passed")

completed = [raw_text.strip() for marker, raw_text in items if is_done(marker, raw_text)]
pending = [raw_text.strip() for marker, raw_text in items if not is_done(marker, raw_text)]
d = json.load(open(spath))
d["completed_steps"] = completed
d["pending_steps"] = pending
d["current_step"] = pending[0] if pending else None
planned_items = [it for it in items if not is_auto_fix(it[1])]
d["total_steps"] = len(planned_items) if planned_items else d.get("total_steps")
if items and not pending and d.get("status") not in ("stopped",):
    d["status"] = "completed"
d["updated_at"] = datetime.datetime.now().astimezone().isoformat()
dump_json(d, spath)

# Seed one ledger task per checklist step (so `task-list`/`status` show every
# step from planning onward, not just steps someone has already run
# `ogre execute` against) and reconcile status against the plan/ledger done
# signal computed above.
if items:
    now = datetime.datetime.now().astimezone().isoformat()
    unlinked_passed = [t for t in issue_tasks if t.get("step") is None and t.get("status") == "passed"]
    changed = False
    planned_counter = 0
    for idx, (marker, raw_text) in enumerate(items, start=1):
        step_text = raw_text.strip()
        auto_fix = is_auto_fix(step_text)
        if not auto_fix:
            planned_counter += 1
        # display_step is the position among planned (non-auto-fix) items
        # only, so it never renumbers when an auto-fix line is inserted
        # elsewhere in the file - unlike step_index (physical position, used
        # for execution ordering), which is left exactly as before.
        display_step = None if auto_fix else planned_counter
        done = is_done(marker, raw_text)
        t = by_text.get(step_text)
        if t is None and done and unlinked_passed:
            # Best-effort migration: adopt one pre-existing (legacy) passed
            # task that predates step-tracking instead of creating a duplicate.
            t = unlinked_passed.pop(0)
            t["step"] = step_text
            t["step_index"] = idx
            t["auto_fix"] = auto_fix
            t["display_step"] = display_step
            t["updated_at"] = now
            changed = True
        elif t is None:
            t = {
                "id": "task-{}".format(uuid.uuid4()), "issue": issue, "type": "execute",
                "executor": None, "model": None, "mode": None, "freshness": None,
                "runner": None, "log_path": None,
                "status": "passed" if done else "pending",
                "pid": None, "exit_code": 0 if done else None, "session_id": None,
                "notes": None,
                "step": step_text, "step_index": idx,
                "auto_fix": auto_fix, "display_step": display_step,
                "created_at": now, "started_at": None,
                "ended_at": now if done else None, "updated_at": now,
            }
            tasks.append(t)
            changed = True
        else:
            if t.get("step_index") != idx:
                t["step_index"] = idx
                changed = True
            if t.get("auto_fix") != auto_fix or t.get("display_step") != display_step:
                t["auto_fix"] = auto_fix
                t["display_step"] = display_step
                changed = True
            if done and t.get("status") != "passed":
                t["status"] = "passed"
                if t.get("exit_code") is None:
                    t["exit_code"] = 0
                if not t.get("ended_at"):
                    t["ended_at"] = now
                t["updated_at"] = now
                changed = True
    if changed:
        dump_json(tasks, tasks_path)
PY
}

# Human-readable job summary: id, issue, status, plan, progress ratio, and
# only the commands that make sense for the current status.
print_job_summary() {
  local issue="$1"
  local spath
  spath="$(state_path "$issue")"
  [ -f "$spath" ] || return 0
  if [ "$(json_field "$spath" status 2>/dev/null)" = "completed" ]; then
    log "Boom! Issue $issue has been resolved."
    log ""
  fi
  python3 - "$spath" "$(tasks_path)" "$issue" <<'PY'
import json, os, sys

def short(t, n=40):
    t = " ".join(t.split())
    return t if len(t) <= n else t[: n - 1].rstrip() + "…"

def table(rows):
    rows = [(k, v if v is not None else "-") for k, v in rows]
    w1 = max(len(str(k)) for k, _ in rows)
    w2 = max(len(str(v)) for _, v in rows)
    sep = "+-{}-+-{}-+".format("-" * w1, "-" * w2)
    print(sep)
    for k, v in rows:
        print("| {:<{w1}} | {:<{w2}} |".format(str(k), str(v), w1=w1, w2=w2))
    print(sep)

def table_cols(headers, rows):
    widths = [len(h) for h in headers]
    for r in rows:
        for i, c in enumerate(r):
            widths[i] = max(widths[i], len(str(c)))
    sep2 = "+-" + "-+-".join("-" * w for w in widths) + "-+"
    def fmt(r):
        return "| " + " | ".join("{:<{w}}".format(str(c), w=w) for c, w in zip(r, widths)) + " |"
    print(sep2)
    print(fmt(headers))
    print(sep2)
    for r in rows:
        print(fmt(r))
    print(sep2)

d = json.load(open(sys.argv[1]))
issue = d.get("issue")
job_id = d.get("job_id")
status = d.get("status")
plan_path = d.get("plan_path")
completed = d.get("completed_steps") or []
pending = d.get("pending_steps") or []
total = d.get("total_steps") or 0
plan_exists = bool(plan_path) and os.path.isfile(plan_path)
plan_display = "{}{}".format(plan_path, "" if plan_exists else "  (not written yet)")

rows = [
    ("Job Id", job_id),
    ("Issue", issue),
    ("Status", status),
    ("Plan", plan_display),
    ("Steps Completed", len(completed)),
    ("Steps Remaining", len(pending)),
    ("Steps Total", total),
    ("View status", "ogre status {}".format(issue)),
]
if plan_exists and status != "completed":
    rows.append(("Review plan", "ogre review-plan {}".format(issue)))
    rows.append(("Execute next", "ogre execute {}".format(issue)))
if status == "completed":
    rows.append(("Archive", "ogre stop {} --archive".format(issue)))
    rows.append(("Delete", "ogre stop {} --delete".format(issue)))
    rows.append(("List files", "ogre stop {} --list".format(issue)))
elif status != "stopped":
    rows.append(("Stop", "ogre stop {}".format(issue)))
table(rows)

try:
    all_tasks = json.load(open(sys.argv[2]))
except Exception:
    all_tasks = []
all_steps = sorted(
    [t for t in all_tasks if t.get("issue") == sys.argv[3] and t.get("step_index") is not None],
    key=lambda t: t["step_index"],
)
steps = [t for t in all_steps if not t.get("auto_fix")]
auto_fix_steps = [t for t in all_steps if t.get("auto_fix")]
display = {"passed": "completed", "running": "running", "failed": "failed", "stopped": "stopped"}
if steps:
    print("Steps ({}):".format(len(steps)))
    step_rows = [
        (t.get("display_step", t["step_index"]), display.get(t.get("status"), "pending"), t.get("id"), short(t.get("step") or ""))
        for t in steps
    ]
    table_cols(["#", "Status", "Task Id", "Step"], step_rows)
if auto_fix_steps:
    # Internal retries spawned by a failed [BROWSER-CHECK] - not part of the
    # plan the user reviewed, shown separately so the step count above never
    # jumps just because one of these fired.
    print("Auto-fixes ({}, internal):".format(len(auto_fix_steps)))
    fix_rows = [
        (display.get(t.get("status"), "pending"), t.get("id"), short(t.get("step") or ""))
        for t in auto_fix_steps
    ]
    table_cols(["Status", "Task Id", "Step"], fix_rows)

blocker_paths = d.get("blocker_paths") or []
blocker_remarks = d.get("blocker_remarks") or {}
if blocker_paths:
    print("Blockers ({}):".format(len(blocker_paths)))
    blk_rows = [
        (os.path.basename(bp), short(blocker_remarks.get(bp) or "-", 50))
        for bp in blocker_paths
    ]
    table_cols(["Blocker", "Remark"], blk_rows)
PY
}

# Human-readable task summary: id, parent issue, status, log, and only the
# commands that make sense (tasks have no review/execute of their own).
print_task_summary() {
  local tid="$1"
  python3 - "$(tasks_path)" "$tid" "$RUNTIME" <<'PY'
import json, sys

def table(rows):
    rows = [(k, v if v is not None else "-") for k, v in rows]
    w1 = max(len(str(k)) for k, _ in rows)
    w2 = max(len(str(v)) for _, v in rows)
    sep = "+-{}-+-{}-+".format("-" * w1, "-" * w2)
    print(sep)
    for k, v in rows:
        print("| {:<{w1}} | {:<{w2}} |".format(str(k), str(v), w1=w1, w2=w2))
    print(sep)

path, tid, runtime = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
t = next((x for x in tasks if x.get("id") == tid), None)
if not t:
    sys.exit(0)

issue = t.get("issue")
job_id = None
try:
    job_id = json.load(open("{}/state/issue-{}.json".format(runtime, issue))).get("job_id")
except Exception:
    pass

issue_tasks = [x for x in tasks if x.get("issue") == issue]
planned_tasks = [x for x in issue_tasks if x.get("step_index") is not None and not x.get("auto_fix")]
total_steps = len({x.get("display_step") for x in planned_tasks if x.get("display_step") is not None}) or len(planned_tasks)
cur_step = t.get("step_index")

if t.get("auto_fix"):
    step_display = "auto-fix (internal, not one of the {} planned steps)".format(total_steps)
elif t.get("display_step") is not None:
    step_display = "{} of {}".format(t.get("display_step"), total_steps)
elif cur_step is not None:
    step_display = "{} of {}".format(cur_step, total_steps)
else:
    step_display = "-"

model = t.get("model")
rows = [
    ("Task Id", t.get("id")),
    ("Job Id", job_id or "(unknown)"),
    ("Issue", issue),
    ("Status", t.get("status")),
    ("Step", step_display),
    ("Executor", "{}{}".format(t.get("executor"), "  ({})".format(model) if model else "")),
    ("Log", t.get("log_path")),
]
if t.get("session_id"):
    rows.append(("Session id", t.get("session_id")))
if t.get("notes"):
    rows.append(("Notes", t.get("notes")))
rows.append(("View status", "ogre status --task {}".format(tid)))
if t.get("status") in ("pending", "running"):
    rows.append(("Stop task", "ogre stop --task {}".format(tid)))
table(rows)
PY
}

# List every task under one job (all `ogre execute` attempts for that
# issue), one row per task, newest first.
cmd_task_list() {
  ensure_runtime
  local job_id="${1:-}"
  [ -n "$job_id" ] || { err "Usage: ogre task-list <job-id>"; exit 1; }
  local issue
  issue="$(resolve_issue_by_job_id "$job_id")"
  [ -n "$issue" ] || { err "No issue found with job id $job_id"; exit 1; }
  sync_state_from_plan "$issue"
  reap_all_tasks
  python3 - "$(tasks_path)" "$issue" "$job_id" <<'PY'
import json, sys

def short(t, n=60):
    t = " ".join(str(t).split())
    return t if len(t) <= n else t[: n - 1].rstrip() + "…"

def table(headers, rows):
    widths = [len(h) for h in headers]
    for r in rows:
        for i, c in enumerate(r):
            widths[i] = max(widths[i], len(str(c)))
    sep = "+-" + "-+-".join("-" * w for w in widths) + "-+"
    def fmt(r):
        return "| " + " | ".join("{:<{w}}".format(str(c), w=w) for c, w in zip(r, widths)) + " |"
    print(sep)
    print(fmt(headers))
    print(sep)
    for r in rows:
        print(fmt(r))
    print(sep)

path, issue, job_id = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
tasks = [t for t in tasks if str(t.get("issue")) == issue]
tasks.sort(key=lambda t: t.get("step_index") if t.get("step_index") is not None else 10**9)

print("Job Id: {}   Issue: {}".format(job_id, issue))
if not tasks:
    print("No tasks yet for this job.")
    sys.exit(0)

rows = []
for t in tasks:
    model = t.get("model")
    executor = "{}{}".format(t.get("executor") or "-", " ({})".format(model) if model else "")
    if t.get("auto_fix"):
        num = "auto-fix"
    elif t.get("display_step") is not None:
        num = t.get("display_step")
    else:
        num = t.get("step_index") if t.get("step_index") is not None else "-"
    rows.append((
        num,
        t.get("id"),
        t.get("status"),
        executor,
        short(t.get("step") or ""),
    ))
step_tasks = [t for t in tasks if t.get("step_index") is not None]
planned_count = len([t for t in step_tasks if not t.get("auto_fix")])
auto_fix_count = len(step_tasks) - planned_count
print("Steps: {}{}".format(
    planned_count,
    "  (+{} internal auto-fix)".format(auto_fix_count) if auto_fix_count else "",
))
table(["#", "Task Id", "Status", "Executor", "Step"], rows)
print("View one:  ogre status --task <task-id>")
PY
}

get_plan_path() {
  local arg="$1"
  if [ -f "$arg" ]; then
    echo "$arg"
    return
  fi
  local issue="$arg"
  issue="${issue#issue-}"
  issue="${issue%.md}"
  if [ -f "$RUNTIME/plans/issue-$issue.md" ]; then
    echo "$RUNTIME/plans/issue-$issue.md"
  else
    echo "$RUNTIME/plans/$arg.md"
  fi
}

confirm_existing_plan() {
  local plan="$1"
  local issue="$2"
  if [ ! -f "$plan" ]; then
    return 0
  fi

  log "Plan already exists: $plan"
  log "Choose:"
  log "  1) Continue existing work"
  log "  2) Replace plan only"
  log "  3) Archive existing and create new"
  log "  4) Delete all Ogre data for issue and start fresh"
  log "  5) Cancel"
  printf 'Selection [1]: '
  read -r choice || true
  choice="${choice:-1}"

  case "$choice" in
    1)
      log "Continuing existing work."
      return 1
      ;;
    2)
      rm -f "$plan"
      log "Removed existing plan only."
      ;;
    3)
      archive_issue "$issue"
      ;;
    4)
      delete_issue_data "$issue"
      ;;
    5)
      log "Cancelled."
      exit 0
      ;;
    *)
      err "Invalid selection."
      exit 1
      ;;
  esac
}

# issue_plan_file <issue> - the plan file's real path for this issue, honoring
# a custom `--plan NAME.md` recorded in state (plan_path) rather than assuming
# the default plans/issue-<n>.md, so archive/delete/list don't orphan a
# custom-named plan. Only returns it when it lives under $RUNTIME (never a
# user-supplied external path) and exists.
issue_plan_file() {
  local issue="$1" spath plan
  spath="$(state_path "$issue")"
  if [ -f "$spath" ]; then
    plan="$(json_field "$spath" plan_path 2>/dev/null || true)"
  fi
  [ -n "${plan:-}" ] || plan="$RUNTIME/plans/issue-$issue.md"
  case "$plan" in
    "$RUNTIME"/*) [ -f "$plan" ] && echo "$plan" ;;
  esac
  return 0
}

# runtime_blocker_files <issue> - blocker files this issue pulled INTO the
# runtime (from state's blocker_paths), one per line. Skips user-supplied
# external paths (anything not under $RUNTIME - e.g. ./notes/x.md) so we never
# delete a file we didn't create, and skips any blocker still referenced by a
# different issue's state so a shared fetched blocker isn't yanked out from
# under another live job.
runtime_blocker_files() {
  local issue="$1" spath
  spath="$(state_path "$issue")"
  [ -f "$spath" ] || return 0
  python3 - "$spath" "$issue" "$RUNTIME" "$(dirname "$(state_path "$issue")")" <<'PY'
import json, sys, glob, os
spath, issue, runtime, statedir = sys.argv[1:5]
try:
    mine = json.load(open(spath))
except Exception:
    sys.exit(0)
paths = [p for p in (mine.get("blocker_paths") or []) if p.startswith(runtime + "/")]
# Which blocker paths does any OTHER issue still reference?
referenced = set()
for other in glob.glob(os.path.join(statedir, "issue-*.json")):
    if os.path.abspath(other) == os.path.abspath(spath):
        continue
    if other.endswith("-knowledge.md"):
        continue
    try:
        d = json.load(open(other))
    except Exception:
        continue
    for p in (d.get("blocker_paths") or []):
        referenced.add(p)
for p in paths:
    if p not in referenced and os.path.exists(p):
        print(p)
PY
}

archive_issue() {
  local issue="$1"
  local ts dest pruned
  ts="$(date '+%Y%m%d-%H%M%S')"
  dest="$RUNTIME/archive/issue-$issue-$ts"
  mkdir -p "$dest"
  [ -f "$RUNTIME/issues/issue-$issue.md" ] && mkdir -p "$dest/issues" && mv "$RUNTIME/issues/issue-$issue.md" "$dest/issues/"
  local _plan _blk
  _plan="$(issue_plan_file "$issue")"
  [ -n "$_plan" ] && mkdir -p "$dest/plans" && mv "$_plan" "$dest/plans/"
  while IFS= read -r _blk; do
    [ -n "$_blk" ] || continue
    mkdir -p "$dest/issues" && mv "$_blk" "$dest/issues/"
  done < <(runtime_blocker_files "$issue")
  [ -d "$RUNTIME/reviews/issue-$issue" ] && mkdir -p "$dest/reviews" && mv "$RUNTIME/reviews/issue-$issue" "$dest/reviews/"
  [ -d "$RUNTIME/logs/issue-$issue" ] && mkdir -p "$dest/logs" && mv "$RUNTIME/logs/issue-$issue" "$dest/logs/"
  [ -f "$RUNTIME/state/issue-$issue.json" ] && mkdir -p "$dest/state" && mv "$RUNTIME/state/issue-$issue.json" "$dest/state/"
  [ -f "$(knowledge_path "$issue")" ] && mkdir -p "$dest/state" && mv "$(knowledge_path "$issue")" "$dest/state/"
  # Prune this issue's rows from the shared ledger, same as delete does. The
  # ledger is never GC'd on its own (every checklist step is seeded as a task,
  # see sync_state_from_plan), so without this an archived issue's tasks stay
  # in tasks.json forever - orphaned (their state file just moved to archive/,
  # so sync can no longer reconcile them) and still counted by status/task-list.
  pruned="$(prune_tasks_for_issue "$issue")"
  log "Archived issue $issue to $dest"
  [ -n "$pruned" ] && log "Pruned $pruned task(s) for issue $issue from the shared ledger."
  return 0   # don't let the trailing && test's exit status leak out under set -e
}

list_issue_files() {
  local issue="$1" _plan _blk
  [ -f "$RUNTIME/issues/issue-$issue.md" ] && echo "$RUNTIME/issues/issue-$issue.md"
  while IFS= read -r _blk; do [ -n "$_blk" ] && echo "$_blk"; done < <(runtime_blocker_files "$issue")
  _plan="$(issue_plan_file "$issue")"
  [ -n "$_plan" ] && echo "$_plan"
  [ -f "$RUNTIME/plans/issue-$issue.md" ] && [ "$_plan" != "$RUNTIME/plans/issue-$issue.md" ] && echo "$RUNTIME/plans/issue-$issue.md"
  [ -d "$RUNTIME/reviews/issue-$issue" ] && echo "$RUNTIME/reviews/issue-$issue"
  [ -d "$RUNTIME/logs/issue-$issue" ] && echo "$RUNTIME/logs/issue-$issue"
  [ -f "$RUNTIME/state/issue-$issue.json" ] && echo "$RUNTIME/state/issue-$issue.json"
  [ -f "$(knowledge_path "$issue")" ] && echo "$(knowledge_path "$issue")"
  [ -d "$RUNTIME/tmp/issue-$issue" ] && echo "$RUNTIME/tmp/issue-$issue"
  return 0
}

delete_issue_data() {
  local issue="$1"
  local pruned _plan _blk
  # Resolve plan + blocker files from state BEFORE the state json is removed.
  _plan="$(issue_plan_file "$issue")"
  local -a blk_files=()
  while IFS= read -r _blk; do [ -n "$_blk" ] && blk_files+=("$_blk"); done < <(runtime_blocker_files "$issue")
  rm -f "$RUNTIME/issues/issue-$issue.md" "$RUNTIME/plans/issue-$issue.md" "$RUNTIME/state/issue-$issue.json" "$(knowledge_path "$issue")"
  [ -n "$_plan" ] && rm -f "$_plan"
  [ ${#blk_files[@]} -gt 0 ] && rm -f "${blk_files[@]}"
  rm -rf "$RUNTIME/reviews/issue-$issue" "$RUNTIME/logs/issue-$issue" "$RUNTIME/tmp/issue-$issue"
  pruned="$(prune_tasks_for_issue "$issue")"
  log "Deleted Ogre data for issue $issue. Code changes were not reverted."
  [ -n "$pruned" ] && log "Pruned $pruned task(s) for issue $issue from the shared ledger."
  return 0
}

# Removes every ledger entry for one issue from the shared tasks.json - the
# ledger is never pruned on its own (every checklist step gets seeded as a
# task, see sync_state_from_plan), so without this it grows forever even
# after the issue itself is deleted.
prune_tasks_for_issue() {
  local issue="$1"
  local path
  path="$(tasks_path)"
  [ -f "$path" ] || return 0
  py_state "$path" "$issue" <<'PY'
import sys
path, issue = sys.argv[1], sys.argv[2]
_lk = lock_state(path)
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
before = len(tasks)
tasks = [t for t in tasks if t.get("issue") != issue]
removed = before - len(tasks)
if removed:
    dump_json(tasks, path)
    print(removed)
PY
}

# Drop every ledger row whose issue no longer has a live state file - a safety
# net for orphaned tasks left behind when an issue's state was archived (moved
# to archive/) or its state file was deleted/lost outside `ogre stop --delete`.
# prune_tasks_for_issue handles the archive/delete paths at the source; this is
# the belt-and-suspenders GC run opportunistically from `ogre status` (no args)
# so a stale ledger self-heals instead of growing without bound. Prints the
# number removed. Never touches a row whose issue still has state (a live or
# in-flight job always has one - write_state creates it before any task).
compact_tasks_ledger() {
  local path statedir
  path="$(tasks_path)"
  [ -f "$path" ] || return 0
  statedir="$(dirname "$path")"
  py_state "$path" "$statedir" <<'PY'
import sys, glob, os
path, statedir = sys.argv[1], sys.argv[2]
_lk = lock_state(path)
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
live = set()
for p in glob.glob(os.path.join(statedir, "issue-*.json")):
    b = os.path.basename(p)
    live.add(b[len("issue-"):-len(".json")])
before = len(tasks)
kept = [t for t in tasks if str(t.get("issue")) in live]
removed = before - len(kept)
if removed:
    dump_json(kept, path)
    print(removed)
PY
}

cmd_init() {
  ensure_runtime
  log "Ogre runtime initialized at $RUNTIME"
}

cmd_feature() {
  ensure_runtime
  local current="" plan_name="" planner="" model="" reasoning="" statement="" name="" browser_check="false"
  # Blockers are collected as two parallel arrays: block_refs[i] is the
  # blocker reference, block_remarks[i] its (optional) freeform status remark.
  # `--blocks a,b` adds refs with no remark; `--blocker REF --remarks TEXT`
  # attaches a remark to the ref that immediately precedes it.
  local -a block_refs=() block_remarks=()
  if [ $# -gt 0 ] && [[ "$1" != --* ]]; then
    current="$1"; shift
  fi

  while [ $# -gt 0 ]; do
    case "$1" in
      --blocks)
        local _ref
        IFS=',' read -ra _refs <<< "${2:-}"
        for _ref in "${_refs[@]}"; do
          _ref="$(echo "$_ref" | xargs)"
          [ -n "$_ref" ] || continue
          block_refs+=("$_ref"); block_remarks+=("")
        done
        shift 2 ;;
      --blocker) block_refs+=("${2:-}"); block_remarks+=(""); shift 2 ;;
      --remarks)
        [ ${#block_refs[@]} -gt 0 ] || { err "--remarks must follow a --blocker (or --blocks) it annotates"; exit 1; }
        block_remarks[$((${#block_remarks[@]} - 1))]="${2:-}"; shift 2 ;;
      --plan) plan_name="${2:-}"; shift 2 ;;
      --planner) planner="${2:-}"; shift 2 ;;
      --model) model="${2:-}"; shift 2 ;;
      --reasoning) reasoning="${2:-}"; shift 2 ;;
      --statement) statement="${2:-}"; shift 2 ;;
      --name) name="${2:-}"; shift 2 ;;
      --browser-check) browser_check="true"; shift ;;
      *) err "Unknown option: $1"; exit 1 ;;
    esac
  done

  # --planner/--model win if passed; else fall back to defaults.planner in
  # .ai/.ogre/config.json; else the hardcoded claude/claude-sonnet-5 default.
  [ -n "$planner" ] || planner="$(config_default_role planner provider)"
  [ -n "$planner" ] || planner="claude"
  [ -n "$model" ] || model="$(config_default_role planner model)"
  [ -n "$model" ] || model="claude-sonnet-5"

  [ -n "$current" ] || [ -n "$statement" ] || { err "Provide an issue number/url/path, or --statement \"free text\""; usage; exit 1; }

  local issue plan issue_path runner blockers_text logdir
  if [ -n "$statement" ]; then
    if [ -n "$name" ]; then
      validate_slug "$name" "--name"
      issue="$name"
    else
      issue="$(slugify_statement "$statement")"
      [ -n "$issue" ] || issue="adhoc-$(date '+%Y%m%d-%H%M%S')"
    fi
  else
    issue="$(slug_from_issue "$current")"
    [ "$issue" != "unknown" ] || { err "Could not determine issue number. Use --plan and a numeric issue if possible."; exit 1; }
  fi
  if [ -n "$plan_name" ]; then
    # Plain filename only - no directory components. Otherwise "--plan
    # ../../../../tmp/evil.md" would write outside .ai/.ogre/plans entirely.
    case "$plan_name" in
      */*|*..*) err "Invalid --plan: '$plan_name' - must be a plain filename (no '/', no '..'), e.g. issue-107-v2.md"; exit 1 ;;
    esac
  fi
  plan_name="${plan_name:-issue-$issue.md}"
  plan="$RUNTIME/plans/$plan_name"
  issue_path="$RUNTIME/issues/issue-$issue.md"
  logdir="$RUNTIME/logs/issue-$issue"
  mkdir -p "$logdir" "$RUNTIME/tmp/issue-$issue"

  if ! confirm_existing_plan "$plan" "$issue"; then
    log "Existing plan preserved. Use: ogre status $issue"
    exit 0
  fi
  # Choice 4 (delete_issue_data) removes logdir/tmp - recreate them since
  # they're used unconditionally below regardless of which choice ran.
  mkdir -p "$logdir" "$RUNTIME/tmp/issue-$issue"

  if [ -n "$statement" ]; then
    mkdir -p "$(dirname "$issue_path")"
    cat > "$issue_path" <<EOF2
# Feature Statement (user-provided)

$statement
EOF2
    log "Wrote feature statement: $issue_path" | tee "$logdir/feature.log"
  else
    fetch_issue "$current" "$issue_path" | tee "$logdir/feature.log"
  fi

  blockers_text="none"
  local bpaths=() remark_pairs=()
  if [ ${#block_refs[@]} -gt 0 ]; then
    blockers_text=""
    local _i b rem bpath
    for _i in "${!block_refs[@]}"; do
      b="${block_refs[$_i]}"
      rem="${block_remarks[$_i]}"
      [ -n "$b" ] || continue
      bpath="$(issue_file_path "$b")"
      fetch_issue "$b" "$bpath" | tee -a "$logdir/feature.log"
      prepend_blocker_remark "$bpath" "$rem"
      bpaths+=("$bpath")
      remark_pairs+=("$bpath" "$rem")
      if [ -n "$rem" ]; then
        blockers_text="$blockers_text* \`$bpath\` — remark: \"$rem\"
"
      else
        blockers_text="$blockers_text* \`$bpath\`
"
      fi
    done
  fi

  # [BROWSER-CHECK] is opt-in per plan (--browser-check), not the default -
  # some users just want the feature built and verify it themselves; forcing
  # a browser-check step onto everyone assumes otherwise. Default skips it;
  # the override below is the only thing that changes the blueprint's normal
  # tagging instruction (section 6 of execution-blueprint-prompt.md).
  local browser_check_rule=""
  if [ "$browser_check" != "true" ]; then
    browser_check_rule="* Do NOT tag any step \`[BROWSER-CHECK]\` in this plan, regardless of what the blueprint template's step-tagging section says - skip that tag entirely, even for steps that render/change UI. The user will verify this feature in a real browser themselves. (Re-run \`ogre feature\` with \`--browser-check\` if automated browser verification is wanted instead.)
"
  fi

  runner="$RUNTIME/tmp/issue-$issue/plan-runner.md"
  cat > "$runner" <<EOF2
# Ogre Planning Runner

Read and follow the planning template from:

* \`.ai/.ogre/prompts/execution-blueprint-prompt.md\`

## Current Issue

* \`$issue_path\`

## Blocking Issues

$blockers_text

## Repo Orientation

* Use \`repo_map.md\` if available - orientation only, never proof. If it is older than the latest commit, treat it as unreliable and verify against the working tree.

## Output

* Write the final execution plan to \`$plan\`.

## Rules

* Follow the planning template exactly.
* Create planning output only.
* Do not implement code.
* Do not modify application files.
* Do not keep placeholder issue numbers from the template.
* Use real issue numbers and issue paths from this runner prompt.
${browser_check_rule}
EOF2

  local blocker_paths_json="[]" bremarks_json="{}"
  [ ${#bpaths[@]} -gt 0 ] && blocker_paths_json="$(json_array "${bpaths[@]}")"
  [ ${#remark_pairs[@]} -gt 0 ] && bremarks_json="$(blocker_remarks_json "${remark_pairs[@]}")"
  # Seed reviewer/executor from config.json (same fallback the real
  # review-plan/execute commands use) rather than a hardcoded "claude" -
  # neither role has run yet at feature-creation time, so this is only ever a
  # starting guess; update_role_state overwrites it with the real value the
  # first time review-plan/execute actually runs.
  local seed_reviewer seed_reviewer_model seed_executor seed_executor_model
  seed_reviewer="$(config_default_role plan_reviewer provider)"; [ -n "$seed_reviewer" ] || seed_reviewer="claude"
  seed_reviewer_model="$(config_default_role plan_reviewer model)"; [ -n "$seed_reviewer_model" ] || seed_reviewer_model="claude-sonnet-5"
  seed_executor="$(config_default_role executor provider)"; [ -n "$seed_executor" ] || seed_executor="claude"
  seed_executor_model="$(config_default_role executor model)"; [ -n "$seed_executor_model" ] || seed_executor_model="claude-sonnet-5"
  write_state "$issue" "planning" "$plan" "$planner" "$model" "$seed_reviewer" "$seed_reviewer_model" "$seed_executor" "$seed_executor_model" "$blocker_paths_json" "$bremarks_json"

  log ""
  print_job_summary "$issue"
  log ""
  log "Planning runner created: $runner"
  log "Planner: $planner ${model:+($model)}${reasoning:+ [reasoning: $reasoning]}"
  log "Next inside Claude Code: read $runner and create the plan."
}

cmd_add_blocker() {
  ensure_runtime
  local issue="${1:-}"
  [ -n "$issue" ] || { err "Missing issue for add-blocker"; usage; exit 1; }
  shift || true
  issue="$(slug_from_issue "$issue")"

  local spath
  spath="$(state_path "$issue")"
  [ -f "$spath" ] || { err "No Ogre state found for issue $issue. Run 'ogre feature' first."; exit 1; }

  local blocker="" statement="" name="" force="false" remarks=""
  if [ $# -gt 0 ] && [[ "$1" != --* ]]; then
    blocker="$1"; shift
  fi
  while [ $# -gt 0 ]; do
    case "$1" in
      --statement) statement="${2:-}"; shift 2 ;;
      --name) name="${2:-}"; shift 2 ;;
      --remarks) remarks="${2:-}"; shift 2 ;;
      --force) force="true"; shift ;;
      *) err "Unknown option: $1"; exit 1 ;;
    esac
  done
  [ -n "$blocker" ] || [ -n "$statement" ] || { err "Provide a blocker issue number/url/path, or --statement \"free text\""; exit 1; }
  [ -n "$name" ] && validate_slug "$name" "--name"

  local forced_after_start="false"
  if execution_started "$issue"; then
    if [ "$force" != "true" ]; then
      err "Execution has already started for issue $issue. Blockers can only be added before 'ogre execute' begins."
      err "Use 'ogre stop $issue' to pause, or pass --force to override (already-completed steps won't be retroactively revised)."
      exit 1
    fi
    forced_after_start="true"
  fi

  local plan issue_path logdir runner bpath bslug
  plan="$(json_field "$spath" plan_path)"
  [ -n "$plan" ] || plan="$RUNTIME/plans/issue-$issue.md"
  issue_path="$RUNTIME/issues/issue-$issue.md"
  logdir="$RUNTIME/logs/issue-$issue"
  mkdir -p "$logdir" "$RUNTIME/tmp/issue-$issue"

  if [ -n "$statement" ]; then
    bslug="${name:-blocker-$(date '+%Y%m%d-%H%M%S')}"
    bpath="$RUNTIME/issues/issue-$bslug.md"
    cat > "$bpath" <<EOF2
# Blocker Statement (user-provided)

$statement
EOF2
    log "Wrote blocker statement: $bpath"
  else
    bpath="$(issue_file_path "$blocker")"
    fetch_issue "$blocker" "$bpath" | tee -a "$logdir/feature.log"
  fi
  prepend_blocker_remark "$bpath" "$remarks"

  py_state "$spath" "$bpath" "$remarks" <<'PY'
import sys, datetime
p, bp, remark = sys.argv[1], sys.argv[2], sys.argv[3]
_lk = lock_state(p)
d = json.load(open(p))
bl = d.get('blocker_paths') or []
if bp not in bl:
    bl.append(bp)
d['blocker_paths'] = bl
rm = d.get('blocker_remarks') or {}
if remark:
    rm[bp] = remark
d['blocker_remarks'] = rm
d['status'] = 'planning'
d['updated_at'] = datetime.datetime.now().astimezone().isoformat()
dump_json(d, p)
PY

  local blockers_text="" _rem
  while IFS=$'\t' read -r bp _rem; do
    [ -n "$bp" ] || continue
    if [ -n "$_rem" ]; then
      blockers_text="$blockers_text* \`$bp\` — remark: \"$_rem\"
"
    else
      blockers_text="$blockers_text* \`$bp\`
"
    fi
  done < <(python3 - "$spath" <<'PY'
import json, sys
d = json.load(open(sys.argv[1]))
rm = d.get('blocker_remarks') or {}
for p in (d.get('blocker_paths') or []):
    print("{}\t{}".format(p, rm.get(p) or ""))
PY
)
  [ -n "$blockers_text" ] || blockers_text="none"

  # When forcing a blocker in after execution started, steps that already
  # passed are NOT retroactively re-planned. Surface them so the user and the
  # planner both know the new blocker might contradict finished work. Reconcile
  # first so ledger statuses reflect the plan's checkboxes.
  local passed_text="" passed_section=""
  if [ "$forced_after_start" = "true" ]; then
    sync_state_from_plan "$issue"
    while IFS=$'\t' read -r sidx stext; do
      [ -n "$stext" ] || continue
      passed_text="$passed_text* step $sidx: $stext
"
    done < <(python3 - "$(tasks_path)" "$issue" <<'PY'
import json, sys
path, issue = sys.argv[1], sys.argv[2]
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
passed = [t for t in tasks if t.get("issue") == issue and t.get("status") == "passed"]
passed.sort(key=lambda t: t.get("step_index") if t.get("step_index") is not None else 0)
for t in passed:
    print("{}\t{}".format(t.get("step_index"), " ".join(str(t.get("step") or "").split())))
PY
)
    if [ -n "$passed_text" ]; then
      log ""
      log "WARNING: these steps already passed and were NOT retroactively revised for the new blocker:"
      printf '%s' "$passed_text" | while IFS= read -r line; do [ -n "$line" ] && log "  $line"; done
      log "Review them manually if the blocker conflicts with what they did."
      passed_section="## Already-Completed Steps (not retroactively revised)

These steps already ran and passed before this blocker was added. If the new blocker's requirements conflict with what they did, call that conflict out explicitly in the revised plan (append a note or a new remediation step) - do not silently leave the contradiction in place.

$passed_text"
    fi
  fi

  runner="$RUNTIME/tmp/issue-$issue/plan-runner.md"
  cat > "$runner" <<EOF2
# Ogre Planning Runner (Blocker Update)

Read and follow the planning template from:

* \`.ai/.ogre/prompts/execution-blueprint-prompt.md\`

## Current Issue

* \`$issue_path\`

## Blocking Issues

$blockers_text

## Existing Plan (revise, do not discard)

* \`$plan\`

$passed_section

## Output

* Revise the plan at \`$plan\` to account for the newly added blocker(s).
* Re-check every existing assumption against the updated blocker list.
* Keep sections the new blocker does not affect.

## Rules

* Follow the planning template exactly.
* Revise planning output only.
* Do not implement code.
* Do not modify application files.
* Use real issue numbers and issue paths from this runner prompt.
EOF2

  log ""
  log "Blocker added: $bpath"
  log "State status reset to 'planning' for issue $issue."
  log "Re-planning runner created: $runner"
  log "Next inside Claude Code: read $runner and revise the plan at $plan."
}

cmd_review_plan() {
  ensure_runtime
  local target="${1:-}" reviewer="" model="" reasoning=""
  [ -n "$target" ] || { err "Missing issue or plan path"; usage; exit 1; }
  shift || true
  while [ $# -gt 0 ]; do
    case "$1" in
      --reviewer) reviewer="${2:-}"; shift 2 ;;
      --model) model="${2:-}"; shift 2 ;;
      --reasoning) reasoning="${2:-}"; shift 2 ;;
      *) err "Unknown option: $1"; exit 1 ;;
    esac
  done

  # --reviewer/--model win if passed; else fall back to defaults.plan_reviewer
  # in .ai/.ogre/config.json; else the hardcoded claude/claude-sonnet-5 default.
  [ -n "$reviewer" ] || reviewer="$(config_default_role plan_reviewer provider)"
  [ -n "$reviewer" ] || reviewer="claude"
  [ -n "$model" ] || model="$(config_default_role plan_reviewer model)"
  [ -n "$model" ] || model="claude-sonnet-5"

  local plan issue runner review_dir review_path
  plan="$(get_plan_path "$target")"
  [ -f "$plan" ] || { err "Plan not found: $plan"; exit 1; }
  issue="$(slug_from_issue "$plan")"
  ensure_state_from_plan "$issue" || true
  update_role_state "$issue" reviewer "$reviewer" "$model"
  review_dir="$RUNTIME/reviews/issue-$issue"
  review_path="$review_dir/plan-review.md"
  runner="$RUNTIME/tmp/issue-$issue/plan-review-runner.md"
  mkdir -p "$review_dir" "$RUNTIME/tmp/issue-$issue"

  cat > "$runner" <<EOF2
# Ogre Plan Review Runner

Read and follow the review template from:

* \`.ai/.ogre/prompts/plan-review-prompt.md\`

Review this implementation plan against the repository/codebase:

* \`$plan\`

Write the review to:

* \`$review_path\`

Rules:

* Do not edit code.
* Return only problems and suggested corrections.
* If there are no blocking issues, say so clearly.
EOF2

  log "Plan review runner created: $runner"
  log "Reviewer: $reviewer ${model:+($model)}${reasoning:+ [reasoning: $reasoning]}"
  log "Review output: $review_path"
}

cmd_execute() {
  ensure_runtime
  # iso (isolation mode) has three values:
  #   new        - default: foreground, brand-new codex/claude session, isolated from main context
  #   main       - run inline in the current Claude Code session (no subprocess spawned)
  #   background - same isolation as "new" but detached/non-blocking
  local target="" executor="" model="" reasoning="" mode="next" freshness="fresh" iso="new" job_id="" task_id="" step_n="" assume_yes="false" max_steps="3" retry="false" mcp_config="" codex_unsandboxed_browser_check="false"
  if [ $# -gt 0 ] && [[ ! "$1" =~ ^-- ]]; then
    target="$1"; shift
  fi
  while [ $# -gt 0 ]; do
    case "$1" in
      --job) job_id="${2:-}"; shift 2 ;;
      --task) task_id="${2:-}"; shift 2 ;;
      --step) step_n="${2:-}"; shift 2 ;;
      --executor) executor="${2:-}"; shift 2 ;;
      --model) model="${2:-}"; shift 2 ;;
      --reasoning) reasoning="${2:-}"; shift 2 ;;
      --mcp-config) mcp_config="${2:-}"; shift 2 ;;
      --codex-unsandboxed-browser-check) codex_unsandboxed_browser_check="true"; shift ;;
      --max-steps) max_steps="${2:-3}"; shift 2 ;;
      --retry) retry="true"; shift ;;
      --all) mode="all"; shift ;;
      --next) mode="next"; shift ;;
      --fresh) freshness="fresh"; shift ;;
      --resume) freshness="resume"; shift ;;
      --run) iso="new"; shift ;;               # legacy flag, kept as a no-op alias: "new" is now the default anyway
      --main) iso="main"; shift ;;
      --background) iso="background"; shift ;;
      --yes) assume_yes="true"; shift ;;
      *) err "Unknown option: $1"; exit 1 ;;
    esac
  done
  # --executor wins if passed; else fall back to defaults.executor in
  # .ai/.ogre/config.json; else the hardcoded claude default.
  [ -n "$executor" ] || executor="$(config_default_role executor provider)"
  [ -n "$executor" ] || executor="claude"
  # Browser MCP for [BROWSER-CHECK] steps: --mcp-config flag wins, else the
  # optional browser_mcp field in .ai/.ogre/config.json. When set, it is passed
  # to spawned `claude` sessions (--mcp-config) so a browser-check step can
  # drive a real browser IN ISOLATION instead of being forced into --main.
  # `claude -p` also inherits ambient project/user MCP servers regardless, so
  # if a browser MCP is already configured there this is not even needed - the
  # automatic path just works. codex relies on its own ~/.codex/config.toml
  # mcp_servers (this flag/field does not apply to codex).
  [ -n "$mcp_config" ] || mcp_config="$(config_browser_mcp)"
  [ "$codex_unsandboxed_browser_check" = "true" ] || codex_unsandboxed_browser_check="$(config_codex_unsandboxed_browser_check)"
  # For a codex executor, [BROWSER-CHECK] steps must be steered to the external
  # Playwright MCP: Codex's bundled browser plugin otherwise routes browser
  # work to its desktop-app in-app browser (node_repl/browser-client), which
  # has no session in a headless spawn and fails. This note (injected into the
  # runner only for codex) forces the external MCP and is what makes isolated
  # codex browser-check actually work. Empty for claude, which has no such trap.
  local browser_force_note=""
  if [ "$executor" = "codex" ]; then
    browser_force_note="Browser tools (mandatory for any [BROWSER-CHECK] work): use ONLY the external \"playwright\" MCP server tools (browser_navigate, browser_snapshot, etc.) directly. Do NOT use node_repl, the in-app browser, agent.browsers, or browser-client - those require the Codex desktop app and have no session in this headless spawn, so they will fail."
  fi
  [ -n "$model" ] || model="$(config_default_role executor model)"
  if [ -z "$model" ]; then
    case "$executor" in
      codex) model="gpt-5.6-sol" ;;
      *) model="claude-sonnet-5" ;;
    esac
  fi
  if [ -n "$job_id" ]; then
    target="$(resolve_issue_by_job_id "$job_id")"
    [ -n "$target" ] || { err "No issue found with job id $job_id"; exit 1; }
  fi
  [ -n "$target" ] || { err "Missing issue, plan path, or --job <job-id>"; usage; exit 1; }
  case "$max_steps" in
    ''|*[!0-9]*|0) err "Invalid --max-steps: $max_steps (must be a positive integer)"; exit 1 ;;
  esac
  if [ "$retry" = "true" ] && [ "$mode" = "all" ]; then
    err "--retry targets one failed step; it can't be combined with --all"
    exit 1
  fi

  local plan issue runner logdir logpath tid spath
  # Set true only for the single-step (non --all) path, when the specifically
  # targeted task's own text is tagged [BROWSER-CHECK] - --task/--step can
  # pick a step out of order, so this must reflect the actual picked task,
  # not next_step_is_browser_check()'s plan-sequential "current_step" (which
  # --all mode uses instead, re-checked fresh per chain link). Read by
  # run_link_foreground/run_link_background_body to scope the codex
  # unsandboxed-browser-check bypass to only the step that actually needs it.
  local target_is_browser_check="false"
  plan="$(get_plan_path "$target")"
  [ -f "$plan" ] || { err "Plan not found: $plan"; exit 1; }
  issue="$(slug_from_issue "$plan")"
  sync_state_from_plan "$issue"
  update_role_state "$issue" executor "$executor" "$model"
  seed_knowledge "$issue"  # lazily seed for jobs created before knowledge bases existed
  spath="$(state_path "$issue")"
  logdir="$RUNTIME/logs/issue-$issue"
  mkdir -p "$logdir" "$RUNTIME/tmp/issue-$issue"
  runner="$RUNTIME/tmp/issue-$issue/run-next.md"

  # True if the plan's current (next-to-run) step is tagged [BROWSER-CHECK].
  # An [AUTO-FIX ...] line is checked and excluded FIRST: it's a normal edit
  # step, but its own text embeds the original failed item's text (which
  # contains "[BROWSER-CHECK]") inside its reason snippet, so the substring
  # match below would otherwise misfire on it too - wrongly forcing it through
  # the browser-MCP gate and, for codex, wrongly running it fully unsandboxed
  # via --dangerously-bypass-approvals-and-sandbox instead of
  # --sandbox workspace-write (see link_wants_unsandboxed_browser_check).
  next_step_is_browser_check() {
    local next_step
    next_step="$(json_field "$spath" current_step 2>/dev/null)"
    printf '%s' "$next_step" | grep -q '^\[AUTO-FIX ' && return 1
    printf '%s' "$next_step" | grep -qi '\[browser-check\]'
  }

  # Best-effort: can the chosen executor drive a real browser from an isolated
  # spawn? Positive signals only, biased to "no" - a false "no" just falls the
  # step back to --main (which always completes), whereas a false "yes" would
  # spawn a step that can't verify and stalls it pending. Signals:
  #   - an explicit browser_mcp / --mcp-config is configured, or
  #   - a browser-ish MCP server appears in the executor's own MCP config.
  # `claude -p` / `codex exec` also inherit these ambient servers at run time,
  # so a positive signal here means the isolated session really will have the
  # tools.
  browser_mcp_available() {
    case "$executor" in
      claude)
        # Verified working: a spawned `claude -p --permission-mode
        # bypassPermissions` inherits the ambient project/user MCP servers and
        # drives a real (headless) browser through a Playwright MCP. Signal:
        # an explicit --mcp-config/browser_mcp, or a browser-ish server in
        # `claude mcp list`.
        [ -n "$mcp_config" ] && return 0
        command -v claude >/dev/null 2>&1 || return 1
        claude mcp list </dev/null 2>/dev/null | grep -qiE 'playwright|browser|chrome|puppeteer'
        ;;
      codex)
        # Forcing the external Playwright MCP over Codex's desktop-app in-app
        # browser (node_repl/browser-client/agent.browsers.get("iab")) gets
        # the tool call routed correctly, but codex's own sandbox then denies
        # the subprocess spawn a real browser needs (launching Chromium) -
        # confirmed 2026-07-11 by direct repro; a plain `codex mcp list`
        # showing playwright is NOT sufficient signal on its own (false
        # positive - the tool call still gets silently cancelled). The only
        # way found to make it actually complete is
        # --dangerously-bypass-approvals-and-sandbox, which removes ALL
        # sandboxing for that spawn, so it's never assumed here - it's gated
        # on the explicit opt-in (--codex-unsandboxed-browser-check /
        # codex_unsandboxed_browser_check in config.json). Without the
        # opt-in, codex always falls back to --main for [BROWSER-CHECK],
        # which is correct given it genuinely can't verify it isolated.
        [ "$codex_unsandboxed_browser_check" = "true" ] || return 1
        command -v codex >/dev/null 2>&1 || return 1
        codex mcp list </dev/null 2>/dev/null | grep -qiE 'playwright|puppeteer'
        ;;
      *) return 1 ;;
    esac
  }

  # Writes the --all runner file for one chain link (tid/logpath vary per
  # link; plan/issue/executor/model/freshness come from the enclosing
  # cmd_execute call). Each link is told to self-assess its own context
  # budget and hand off cleanly instead of running the whole plan into the
  # ground - that's what lets a chain of small, fully-fresh sessions stand
  # in for one big one without ever needing an external token count.
  write_all_runner() {
    local link_tid="$1" link_logpath="$2"
    cat > "$runner" <<EOF2
# Ogre Execution Runner

Read and follow the execution handoff instructions from:

* \`.ai/.ogre/prompts/execution-handoff.md\`

Use this source plan:

* \`$plan\`

Execution mode:

* Mode: \`all\` (chained)
* Executor: \`$executor\`
* Model: \`${model:-default}\`
* Reasoning: \`${reasoning:-default}\`
* Freshness: \`$freshness\`
* Task id: \`$link_tid\`

$(knowledge_block "$issue")

$(repo_drift_block "$plan")

$(backfill_warning_block "$spath")

Task:

* Execute remaining incomplete checklist items in order, one at a time.
* Follow the handoff rules exactly for each item.
* If an item is tagged \`[BROWSER-CHECK]\`, verify it by actually rendering the page/app with your browser MCP tools (e.g. Playwright) - that is what the tag means. ${browser_force_note:+$browser_force_note }If this session has no browser MCP tools available, do NOT mark the item passed or failed: leave it pending and report that a browser MCP must be configured (set \`browser_mcp\` in \`.ai/.ogre/config.json\`, or pass \`--mcp-config\`; see README) or the step re-run with \`--main\`. If the check genuinely FAILS (real bug found), do NOT edit its checkbox marker or its own checklist line text in any way - leave that exact line untouched (still \`- [ ] <original text>\`, no added notes, no custom marker like \`[FAILED]\`). Report the failure ONLY via \`ogre task-complete <task-id> --status failed\` with the reason in \`--notes\` - Ogre reads that ledger signal (and its own tooling may act on it automatically), not any hand-edited checkbox text.
* Update each checklist item's status in the source plan only after its own work and validation are complete.
* Write a concise execution log to \`$link_logpath\`.
* Hard cap: complete at most $max_steps checklist items in this session, then STOP - even if items remain and your context feels fine. Self-assessed context estimates are unreliable; the cap is the authoritative limit.
* STOP even earlier than the cap if you estimate more than roughly half of your context window is already used after finishing an item.
* Stopping early for the cap or context-budget reasons is normal and expected, not a failure: a fresh session will automatically continue with whatever is left. Do not report it as an error.
* Only stop and mark failed if an item's validation genuinely fails; report which items completed and which didn't.
* Mandatory before finishing: UPDATE the knowledge base at \`$RUNTIME/state/issue-$issue-knowledge.md\` following the rules inside that file - revise the durable sections in place if you confirmed something structural (stack, conventions, structure, a real signature/route/column, a validation command, a gotcha), and append exactly ONE line to its Step Log saying what each item did + the single most useful thing learned. Revise in place, respect the caps, don't append duplicates. Do this even if the step FAILED - a failure's "why" is the most valuable gotcha for the next attempt. If this is the first step, seed the durable sections from what you learned so later steps start informed.
* Mark the ledger task done, mandatory, last step: \`$SCRIPT_DIR/ogre task-complete $link_tid --status passed\` (covers both "finished everything" and "stopped early on purpose for the cap/context") or \`--status failed\` (only for a genuine validation failure). Use this exact path - \`ogre\` alone is not guaranteed to be on PATH.
* Optional: \`--notes "..."\` on that command records a one-liner in the task ledger (visible in \`ogre status\`) - handy for a per-attempt marker, but the knowledge base above is what carries knowledge to the next step, so prefer updating that.

Safety:

* Stop if the working tree contains unrelated changes that are not part of the plan.
* Stop if a \`NEEDS INSPECTION\` item cannot be verified from real code.
* Stop if blocker dependency is missing or incompatible.
EOF2
  }

  # In --all, a [BROWSER-CHECK] next step can run isolated ONLY if the executor
  # has a browser MCP; otherwise stop and hand that one step to --main (the
  # skill auto-loops this for foreground chains). When a browser MCP IS present,
  # the chain runs straight through browser-check steps, fully isolated.
  if [ "$mode" = "all" ] && [ "$iso" != "main" ] && next_step_is_browser_check && ! browser_mcp_available; then
    err "Next step is [BROWSER-CHECK] and no browser MCP was detected for $executor, so a spawned session can't verify it."
    err "Finish that one step with --main first: $SCRIPT_DIR/ogre execute $issue --main"
    err "or give $executor a browser MCP (browser_mcp in .ai/.ogre/config.json / --mcp-config / a Playwright MCP server) to run it isolated - see README."
    err "Then resume the chain: $SCRIPT_DIR/ogre execute $issue --all"
    exit 1
  fi

  if [ "$mode" = "all" ]; then
    # Chained bulk path: a sequence of ad-hoc tasks, each covering as many
    # remaining checklist items as one session's own context budget allows.
    # Not tied to any single seeded step task.
    tid="$(new_task_id)"
    logpath="$logdir/execute-$(date '+%Y%m%d-%H%M%S')-${tid:5:8}.log"
    write_all_runner "$tid" "$logpath"
    task_create "$tid" "$issue" "execute" "$executor" "$model" "$mode" "$freshness" "$runner" "$logpath" "pending"
  else
    # Default: target exactly one seeded step-task. Explicit --task/--step
    # picks it out of order; otherwise take the lowest step_index pending.
    local pick tid blockers_msg
    pick="$(python3 - "$(tasks_path)" "$issue" "$task_id" "$step_n" "$retry" <<'PY'
import json, sys
path, issue, task_id, step_n, retry = sys.argv[1:6]
try:
    tasks = json.load(open(path))
except Exception:
    tasks = []
issue_tasks = [t for t in tasks if t.get("issue") == issue]
target = None
if task_id:
    target = next((t for t in issue_tasks if t.get("id") == task_id), None)
elif step_n:
    try:
        n = int(step_n)
    except ValueError:
        n = None
    target = next((t for t in issue_tasks if t.get("step_index") == n), None)
elif retry == "true":
    failed = sorted(
        [t for t in issue_tasks if t.get("status") == "failed"],
        key=lambda t: t.get("step_index") if t.get("step_index") is not None else 0,
    )
    target = failed[0] if failed else None
else:
    pending = sorted(
        [t for t in issue_tasks if t.get("status") in ("pending", "stopped")],
        key=lambda t: t.get("step_index") if t.get("step_index") is not None else 0,
    )
    target = pending[0] if pending else None
resume_flag = "stopped" if target and target.get("status") == "stopped" else ""
blockers_msg = ""
if target and (task_id or step_n):
    idx = target.get("step_index")
    if idx is not None:
        blockers = sorted(
            (
                t for t in issue_tasks
                if t.get("id") != target.get("id")
                and t.get("step_index") is not None
                and t.get("step_index") < idx
                and t.get("status") != "passed"
            ),
            key=lambda t: t.get("step_index"),
        )
        if blockers:
            names = ", ".join(
                "step {} ({})".format(b.get("step_index"), b.get("status"))
                for b in blockers
            )
            blockers_msg = "earlier {} not yet passed: {}".format(
                "step" if len(blockers) == 1 else "steps", names
            )
print(target.get("id") if target else "")
print(blockers_msg)
print(resume_flag)
PY
)"
    tid="$(printf '%s\n' "$pick" | sed -n '1p')"
    blockers_msg="$(printf '%s\n' "$pick" | sed -n '2p')"
    local resume_flag
    resume_flag="$(printf '%s\n' "$pick" | sed -n '3p')"
    if [ -z "$tid" ]; then
      if [ -n "$task_id" ] || [ -n "$step_n" ]; then
        err "No matching pending task for that --task/--step under issue $issue"
      elif [ "$retry" = "true" ]; then
        err "No failed step to retry under issue $issue"
      else
        log "No pending steps left for issue $issue. Nothing to execute."
      fi
      exit 1
    fi
    local job_status=""
    [ -f "$spath" ] && job_status="$(json_field "$spath" status 2>/dev/null)"
    if [ "$resume_flag" = "stopped" ] || [ "$job_status" = "stopped" ]; then
      if [ "$resume_flag" = "stopped" ]; then
        log "Step for task $tid was previously stopped (ogre stop). Files kept, code untouched."
      else
        log "Issue $issue (job) is currently marked stopped. Task $tid itself is still pending."
      fi
      if [ "$assume_yes" = "true" ]; then
        log "Proceeding (--yes passed)."
      elif [ -t 0 ]; then
        local resume_confirm=""
        read -r -p "Resume/proceed? [y/N] " resume_confirm
        case "$resume_confirm" in
          y|Y|yes|YES) ;;
          *) log "Aborted."; exit 1 ;;
        esac
      else
        err "Refusing to proceed non-interactively without confirmation. Re-run with --yes to confirm."
        exit 1
      fi
    fi
    if [ -n "$blockers_msg" ]; then
      log "WARNING: $blockers_msg. This task may fail if it depends on their output."
      if [ "$assume_yes" = "true" ]; then
        log "Proceeding (--yes passed)."
      elif [ -t 0 ]; then
        local confirm=""
        read -r -p "Proceed anyway? [y/N] " confirm
        case "$confirm" in
          y|Y|yes|YES) ;;
          *) log "Aborted."; exit 1 ;;
        esac
      else
        err "Refusing to proceed non-interactively without confirmation. Re-run with --yes to confirm."
        exit 1
      fi
    fi
    local step_text step_index
    { read -r step_text; read -r step_index; } < <(task_fields "$tid" step step_index)

    # Capture the failed attempt's log/exit code before this run assigns the
    # task a fresh log path.
    local retry_block=""
    if [ "$retry" = "true" ]; then
      retry_block="$(retry_context_block "$(task_field "$tid" log_path)" "$(task_field "$tid" exit_code)")"
    fi

    # A step tagged [BROWSER-CHECK] needs a real rendered browser to verify
    # (see templates/execution-blueprint-prompt.md). It is NOT forced into
    # --main anymore: it spawns isolated like every other step and is expected
    # to drive a browser via MCP tools (inherited ambient MCP, or the
    # browser_mcp/--mcp-config passed to the claude spawn). The runner just
    # tells it to use those tools, and to leave the step pending (not failed)
    # if none are available rather than guessing.
    local browser_check_note=""
    if ! printf '%s' "$step_text" | grep -q '^\[AUTO-FIX ' && printf '%s' "$step_text" | grep -qi '\[browser-check\]'; then
      target_is_browser_check="true"
      browser_check_note="This is a [BROWSER-CHECK] step: verify it by actually rendering the page/app with your browser MCP tools (e.g. Playwright), not just by reading markup/CSS/JS.${browser_force_note:+ $browser_force_note} If it genuinely FAILS (real bug found), do NOT edit its checkbox marker or its own checklist line text in any way - leave that exact line untouched (still \`- [ ] <original text>\`, no added notes, no custom marker like \`[FAILED]\`). Report the failure ONLY via \`ogre task-complete <task-id> --status failed\` with the reason in \`--notes\`."
      if [ "$iso" != "main" ]; then
        if browser_mcp_available; then
          log "Step $step_index is [BROWSER-CHECK] - running isolated; the spawned $executor session will verify it with its browser MCP tools (main context untouched)."
        else
          # No browser MCP for this executor and none configured. Fall back to
          # --main so the step still completes automatically in this session
          # (the whole point is no manual retrigger) rather than spawning a
          # session that can't verify it. Notify so the user knows why, and
          # how to keep it isolated next time.
          iso="main"
          log "NOTE: step $step_index is tagged [BROWSER-CHECK] but no browser MCP was detected for $executor. Falling back to --main so it still completes automatically here (no manual retrigger needed)."
          log "      To keep browser-check steps isolated from this context, give $executor a browser MCP: set \"browser_mcp\" in .ai/.ogre/config.json, pass --mcp-config PATH, or add a Playwright/browser MCP server (see README)."
        fi
      fi
    fi

    logpath="$logdir/execute-$(date '+%Y%m%d-%H%M%S')-${tid:5:8}.log"

    cat > "$runner" <<EOF2
# Ogre Execution Runner

Read and follow the execution handoff instructions from:

* \`.ai/.ogre/prompts/execution-handoff.md\`

Use this source plan:

* \`$plan\`

Execution mode:

* Executor: \`$executor\`
* Model: \`${model:-default}\`
* Reasoning: \`${reasoning:-default}\`
* Freshness: \`$freshness\`
* Task id: \`$tid\`

Target checklist item (step $step_index) - implement exactly this one, nothing else:

* $step_text

$(knowledge_block "$issue")

$(repo_drift_block "$plan")

$(backfill_warning_block "$spath")

$retry_block

$browser_check_note

Task:

* Execute only the target checklist item above.
* Do not execute any other checklist item, even if it looks quick.
* Follow the handoff rules exactly.
* Use a fresh context/session when possible.
* Update the checklist item status in the source plan only after the work and validation are complete.
* Write a concise execution log to \`$logpath\`.
* Stop after reporting changed files and validation result.
* Mandatory before finishing: UPDATE the knowledge base at \`$RUNTIME/state/issue-$issue-knowledge.md\` following the rules inside that file - revise the durable sections in place if you confirmed something structural (stack, conventions, structure, a real signature/route/column, a validation command, a gotcha), and append exactly ONE line to its Step Log saying what this step did + the single most useful thing learned. Revise in place, respect the caps, don't append duplicates. Do this even if the step FAILED - a failure's "why" is the most valuable gotcha for the next attempt. If this is the first step, seed the durable sections from what you learned so later steps start informed.
* Mark the ledger task done, mandatory, last step: \`$SCRIPT_DIR/ogre task-complete $tid --status passed\` (or \`--status failed\` if validation failed). Use this exact path - \`ogre\` alone is not guaranteed to be on PATH. Skipping this leaves the task stuck \`pending\`/\`running\` in \`ogre status\`/\`ogre task-list\` even though the work is done.
* Optional: \`--notes "..."\` on that command records a one-liner in the task ledger (visible in \`ogre status\`) - handy for a per-attempt marker, but the knowledge base above is what carries knowledge to the next step, so prefer updating that.

Safety:

* Stop if the working tree contains unrelated changes that are not part of the plan.
* Stop if validation fails.
* Stop if a \`NEEDS INSPECTION\` item cannot be verified from real code.
* Stop if blocker dependency is missing or incompatible.
EOF2
    task_update "$tid" "executor=$executor" "model=${model:-null}" "freshness=$freshness" "runner=$runner" "log_path=$logpath"
  fi
  if [ -f "$spath" ]; then
    py_state "$spath" "$tid" "$logpath" <<'PY'
import datetime, sys
p, tid, logpath = sys.argv[1:4]
_lk = lock_state(p)
d = json.load(open(p))
d['active_task'] = tid
d['status'] = 'executing'
d['last_log'] = logpath
d['updated_at'] = datetime.datetime.now().astimezone().isoformat()
dump_json(d, p)
PY
  fi

  # Claude lets us pick the session id up front (--session-id); Codex only
  # reveals its own "session id: <uuid>" in its own output, so that one has
  # to be parsed out after the process actually runs.
  local session_id=""
  if [ "$executor" = "claude" ]; then
    session_id="$(gen_uuid)"
    task_update "$tid" "session_id=$session_id"
  fi

  log "Execution runner created: $runner"
  log "Task id: $tid"
  [ -n "$session_id" ] && log "Session id: $session_id (resume in Claude TUI later: claude --resume $session_id)"
  log "Executor: $executor ${model:+($model)}${reasoning:+ [reasoning: $reasoning]}"
  log "Log path: $logpath"

  if [ "$iso" = "main" ]; then
    log ""
    log "Mode: --main. Execute the target checklist item(s) from the runner file above directly in this session (no subprocess spawned)."
    log "Alternatively, run it in an isolated session yourself:"
    log "  codex exec --skip-git-repo-check --sandbox workspace-write ${model:+-m $model} ${reasoning:+-c model_reasoning_effort=$reasoning} - < $runner"
    log ""
    log "Task $tid recorded as pending. Check with: $SCRIPT_DIR/ogre status --task $tid"
    log "When the work is done, mark it: $SCRIPT_DIR/ogre task-complete $tid --status passed|failed"
    return
  fi

  case "$executor" in
    codex) command -v codex >/dev/null 2>&1 || { task_update "$tid" "status=failed"; err "codex CLI not found"; exit 1; } ;;
    claude) command -v claude >/dev/null 2>&1 || { task_update "$tid" "status=failed"; err "claude CLI not found"; exit 1; } ;;
    *) task_update "$tid" "status=failed"; err "Unsupported executor: $executor"; exit 1 ;;
  esac

  # Runs one subprocess link (foreground, blocking) for the given tid/runner/
  # logpath/session id, streaming to both stdout and the log file. Echoes
  # the exit code as the last line of stdout (caller captures it).
  # True if THIS about-to-run link should use codex's unsandboxed browser-check
  # bypass: opted in, AND the step this link is actually about to work on is
  # tagged [BROWSER-CHECK]. --all mode re-checks the plan's live next step
  # (chain links are spawned one at a time, state is synced between them);
  # single-step mode uses the specifically targeted task's own text (set once
  # into target_is_browser_check, since --task/--step can go out of order).
  link_wants_unsandboxed_browser_check() {
    [ "$codex_unsandboxed_browser_check" = "true" ] || return 1
    if [ "$mode" = "all" ]; then
      next_step_is_browser_check
    else
      [ "$target_is_browser_check" = "true" ]
    fi
  }

  run_link_foreground() {
    local link_tid="$1" link_runner="$2" link_logpath="$3" link_session="$4"
    local rc
    set +e
    case "$executor" in
      codex)
        local -a codex_args=(exec --skip-git-repo-check)
        if link_wants_unsandboxed_browser_check; then
          log "WARNING: running this codex step UNSANDBOXED (--dangerously-bypass-approvals-and-sandbox) - opted in via --codex-unsandboxed-browser-check/config for its [BROWSER-CHECK] step. No filesystem/shell/network confinement for this one spawn."
          codex_args+=(--dangerously-bypass-approvals-and-sandbox)
        else
          codex_args+=(--sandbox workspace-write)
        fi
        [ -n "$model" ] && codex_args+=(-m "$model")
        [ -n "$reasoning" ] && codex_args+=(-c "model_reasoning_effort=$reasoning")
        codex "${codex_args[@]}" - < "$link_runner" | tee "$link_logpath"
        ;;
      claude)
        local -a claude_args=(-p --permission-mode bypassPermissions --session-id "$link_session")
        [ -n "$model" ] && claude_args+=(--model "$model")
        [ -n "$reasoning" ] && claude_args+=(--effort "$reasoning")
        [ -n "$mcp_config" ] && claude_args+=(--mcp-config "$mcp_config")
        claude "${claude_args[@]}" < "$link_runner" | tee "$link_logpath"
        ;;
    esac
    rc=$?
    set -e
    finalize_link_status "$link_tid" "$rc"
    if [ "$executor" = "codex" ]; then
      local codex_sid
      codex_sid="$(grep -m1 '^session id: ' "$link_logpath" 2>/dev/null | sed 's/^session id: //')"
      [ -n "$codex_sid" ] && task_update "$link_tid" "session_id=$codex_sid"
    fi
    return "$rc"
  }

  run_link_background_body() {
    local link_tid="$1" link_runner="$2" link_logpath="$3" link_session="$4"
    case "$executor" in
      codex)
        local -a codex_args=(exec --skip-git-repo-check)
        if link_wants_unsandboxed_browser_check; then
          log "WARNING: running this codex step UNSANDBOXED (--dangerously-bypass-approvals-and-sandbox) - opted in via --codex-unsandboxed-browser-check/config for its [BROWSER-CHECK] step. No filesystem/shell/network confinement for this one spawn."
          codex_args+=(--dangerously-bypass-approvals-and-sandbox)
        else
          codex_args+=(--sandbox workspace-write)
        fi
        [ -n "$model" ] && codex_args+=(-m "$model")
        [ -n "$reasoning" ] && codex_args+=(-c "model_reasoning_effort=$reasoning")
        codex "${codex_args[@]}" - < "$link_runner" > "$link_logpath" 2>&1
        ;;
      claude)
        local -a claude_args=(-p --permission-mode bypassPermissions --session-id "$link_session")
        [ -n "$model" ] && claude_args+=(--model "$model")
        [ -n "$reasoning" ] && claude_args+=(--effort "$reasoning")
        [ -n "$mcp_config" ] && claude_args+=(--mcp-config "$mcp_config")
        claude "${claude_args[@]}" < "$link_runner" > "$link_logpath" 2>&1
        ;;
    esac
    local rc=$?
    finalize_link_status "$link_tid" "$rc"
    if [ "$executor" = "codex" ]; then
      local codex_sid
      codex_sid="$(grep -m1 '^session id: ' "$link_logpath" 2>/dev/null | sed 's/^session id: //')"
      [ -n "$codex_sid" ] && task_update "$link_tid" "session_id=$codex_sid"
    fi
    return "$rc"
  }

  # The subprocess (codex/claude) is expected to call
  # `ogre task-complete <tid> --status passed|failed` itself as part of the
  # handoff instructions - that ledger write is the real domain signal
  # (validation passed/failed), independent of the CLI process's own exit
  # code (which is usually 0 even on a validation failure, since the LLM
  # just reported it rather than crashing). If the subprocess never touched
  # the ledger at all (crashed, forgot the step, or its task-complete call
  # silently failed), fail closed: mark it failed rather than guessing
  # passed from a bare rc==0. rc==0 only proves the CLI exited cleanly, not
  # that the domain task passed - trusting it as "passed" lets a broken
  # step masquerade as done and corrupts progress tracking undetected. A
  # false "failed" here just costs a manual rerun/task-complete.
  finalize_link_status() {
    local link_tid="$1" rc="$2"
    local current_status
    current_status="$(task_field "$link_tid" status)"
    if [ "$current_status" = "passed" ] || [ "$current_status" = "failed" ]; then
      task_update "$link_tid" "exit_code=$rc"
    else
      task_update "$link_tid" "status=failed" "exit_code=$rc"
    fi
  }

  # Ad-hoc [AUTO-FIX] steps for a failed [BROWSER-CHECK]: capped at this many
  # per browser-check item (not configurable - if 2 real attempts can't fix
  # it, it needs a human, not a third guess). See should_continue_chain.
  local auto_fix_cap=2

  # Finds the ledger task id whose "step" field exactly matches the given
  # checklist text (sync_state_from_plan auto-seeds one such task per plan
  # item, matched by exact text - this is how a specific plan line's own
  # ledger record is found without threading a task id through everything).
  find_task_id_by_step() {
    local step_text="$1"
    python3 - "$(tasks_path)" "$issue" "$step_text" <<'PY'
import json, sys
tasks_path, issue, step_text = sys.argv[1:4]
try:
    tasks = json.load(open(tasks_path))
except Exception:
    tasks = []
for t in tasks:
    if t.get("issue") == issue and t.get("step") == step_text:
        print(t.get("id") or "")
        sys.exit(0)
print("")
PY
  }

  # Inserts one ad-hoc "- [ ] [AUTO-FIX n/cap fp:<hash>] Fix ...: <reason>"
  # checklist item into the plan's Execution Order, immediately before the
  # given (still-pending, unchecked) [BROWSER-CHECK] item's own line -
  # fingerprinted by a hash of that item's exact text so repeated attempts
  # are counted correctly regardless of how the plan file shifts around it.
  # Never touches any other line - the real planned steps stay exactly as
  # written. Prints OK / CAP_EXCEEDED / NOT_FOUND on stdout; caller checks it.
  synthesize_auto_fix_step() {
    local target_text="$1" reason="$2" cap="$3"
    python3 - "$plan" "$target_text" "$reason" "$cap" <<'PY'
import hashlib, re, sys
plan_path, target_text, reason, cap = sys.argv[1:5]
cap = int(cap)
text = open(plan_path).read()
fp = hashlib.md5(target_text.encode()).hexdigest()[:8]
existing = len(re.findall(r'\[AUTO-FIX \d+/%d fp:%s\]' % (cap, fp), text))
attempt = existing + 1
if attempt > cap:
    print('CAP_EXCEEDED')
    sys.exit(0)
target_line_re = re.compile(
    r'^([ \t]*[-*]\s*\[ \]\s*)' + re.escape(target_text) + r'\s*$', re.M
)
m = target_line_re.search(text)
if not m:
    print('NOT_FOUND')
    sys.exit(0)
snippet = target_text.strip()
if len(snippet) > 80:
    snippet = snippet[:80] + '...'
reason_snippet = reason.strip().replace('\n', ' ')
if len(reason_snippet) > 600:
    reason_snippet = reason_snippet[:600] + '...'
new_line = (
    '- [ ] [AUTO-FIX {attempt}/{cap} fp:{fp}] Fix the following issue found '
    'verifying "{snippet}", using the smallest safe change: {reason}. If the '
    'true fix needs touching more than about 3 files, or the root cause is '
    'an ambiguous/missing requirement rather than a clear defect, mark this '
    'NEEDS INSPECTION and stop instead of guessing.\n'
).format(attempt=attempt, cap=cap, fp=fp, snippet=snippet, reason=reason_snippet)
insert_at = m.start()
text = text[:insert_at] + new_line + text[insert_at:]
open(plan_path, 'w').write(text)
print('OK')
PY
  }

  # Marks the given (currently-pending) [AUTO-FIX ...] line's checkbox [x] in
  # the plan without claiming success - used when the fix attempt itself
  # failed to complete (crashed, or explicitly bailed with NEEDS INSPECTION).
  # This is purely to stop it blocking progress as the perpetual "current"
  # pending item. Flips ONLY the marker, never the line's own text - changing
  # the text would break sync_state_from_plan's by-text ledger matching
  # (it'd look like a brand new checklist item and orphan/duplicate the
  # existing task instead of resolving it). The attempt-numbered fp tag
  # already on the line is the visible record that this was one of possibly
  # several tries; that's enough for a human reading the plan afterward.
  close_out_stuck_auto_fix_step() {
    local target_text="$1"
    python3 - "$plan" "$target_text" <<'PY'
import re, sys
plan_path, target_text = sys.argv[1:3]
text = open(plan_path).read()
line_re = re.compile(
    r'^([ \t]*[-*]\s*)\[ \](\s*' + re.escape(target_text) + r'\s*)$', re.M
)
m = line_re.search(text)
if not m:
    print('NOT_FOUND')
    sys.exit(0)
replacement = m.group(1) + '[x]' + m.group(2)
text = text[:m.start()] + replacement + text[m.end():]
open(plan_path, 'w').write(text)
print('OK')
PY
  }

  # After a link finishes: passed + steps still pending in the plan means it
  # deliberately handed off on its own context budget - spawn a fresh link
  # to continue. Failed, or nothing left, ends the chain - UNLESS the failure
  # was on a [BROWSER-CHECK] step (or an [AUTO-FIX] step working to unblock
  # one) with a real reason to work from (not a crash/fail-closed, which has
  # nothing to diagnose):
  #   - current pending item is [BROWSER-CHECK] and it just failed -> insert
  #     one ad-hoc [AUTO-FIX] attempt ahead of it, capped at auto_fix_cap
  #     total attempts per browser-check item.
  #   - current pending item is itself an [AUTO-FIX ...] attempt and IT
  #     failed to complete -> close it out (tick it, marked "did not
  #     complete") so the chain falls back to the original [BROWSER-CHECK]
  #     item on the next turn, which re-triggers the branch above for a
  #     fresh attempt (still bounded by the same cap, since closing a stuck
  #     line never resets the count - the count is the number of [AUTO-FIX]
  #     lines that ever existed for that item, closed or not).
  #   - anything else failed -> stop, same as always.
  should_continue_chain() {
    local link_tid="$1"
    [ "$mode" = "all" ] || return 1
    local link_status
    link_status="$(task_field "$link_tid" status)"
    if [ "$link_status" != "passed" ]; then
      [ "$link_status" = "failed" ] || return 1
      local current_step
      current_step="$(json_field "$spath" current_step 2>/dev/null)"
      [ -n "$current_step" ] || return 1
      # [AUTO-FIX ...] must be checked BEFORE the generic [browser-check]
      # substring match: a synthesized line embeds the target's own text
      # (which contains "[BROWSER-CHECK]") inside its reason snippet, so the
      # looser check below would also match an AUTO-FIX line and misfire.
      if printf '%s' "$current_step" | grep -q '^\[AUTO-FIX '; then
        close_out_stuck_auto_fix_step "$current_step" >/dev/null
        log "Ad-hoc [AUTO-FIX] attempt did not complete - closing it out and falling back to the original [BROWSER-CHECK] step for another attempt."
        sync_state_from_plan "$issue"
        return 0
      elif printf '%s' "$current_step" | grep -qi '\[browser-check\]'; then
        local link_log fail_reason fix_result
        link_log="$(task_field "$link_tid" log_path)"
        fail_reason=""
        [ -n "$link_log" ] && [ -f "$link_log" ] && fail_reason="$(tail -n 60 "$link_log" 2>/dev/null)"
        [ -n "$fail_reason" ] || return 1  # nothing to diagnose - stay failed, same as today
        fix_result="$(synthesize_auto_fix_step "$current_step" "$fail_reason" "$auto_fix_cap")"
        case "$fix_result" in
          OK)
            log "[BROWSER-CHECK] failed with a real reason - inserted an ad-hoc [AUTO-FIX] step ahead of it and continuing the chain (capped at $auto_fix_cap attempts)."
            sync_state_from_plan "$issue"
            return 0
            ;;
          CAP_EXCEEDED)
            local x_tid last_error
            x_tid="$(find_task_id_by_step "$current_step")"
            # Fold the real browser error from the LAST attempt into the
            # ledger note and the stop message, not just a pointer to logs -
            # the whole point of the cap is a human reads this once and acts,
            # they shouldn't have to go dig up a log path first to learn what
            # actually failed.
            last_error="$(printf '%s' "$fail_reason" | tr '\n' ' ' | tr -s ' ')"
            if [ "${#last_error}" -gt 600 ]; then
              last_error="${last_error:0:600}..."
            fi
            if [ -n "$x_tid" ]; then
              task_update "$x_tid" "status=failed" "notes=Auto-fix cap ($auto_fix_cap) exceeded. Last verification failure: $last_error -- see the plan file for each [AUTO-FIX] attempt and its own log."
            fi
            err "[BROWSER-CHECK] still failing after $auto_fix_cap ad-hoc [AUTO-FIX] attempts - stopping the chain."
            err "Last verification failure: $last_error"
            err "See the plan's [AUTO-FIX] entries and their logs for every attempt tried."
            return 1
            ;;
          *) return 1 ;;
        esac
      else
        return 1
      fi
    fi
    local pending_left
    # $spath is passed as argv (not spliced into the source) so a slug can
    # never break out of the string literal - consistent with every other
    # state-reading snippet in this script.
    pending_left="$(python3 - "$spath" 2>/dev/null <<'PY'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
    print(len(d.get('pending_steps') or []))
except Exception:
    print(0)
PY
)"
    [ "${pending_left:-0}" -gt 0 ] 2>/dev/null || return 1
    if [ "$iso" != "main" ] && next_step_is_browser_check && ! browser_mcp_available; then
      err "Next step is [BROWSER-CHECK] and no browser MCP was detected for $executor - stopping the --all chain here."
      err "Finish that step with --main ($SCRIPT_DIR/ogre execute $issue --main) or give $executor a browser MCP, then resume: $SCRIPT_DIR/ogre execute $issue --all"
      return 1
    fi
    return 0
  }

  finalize_issue_state() {
    local rc="$1"
    if [ -f "$spath" ]; then
      py_state "$spath" "$rc" <<'PY'
import datetime, sys
p = sys.argv[1]
rc = int(sys.argv[2])
_lk = lock_state(p)
d = json.load(open(p))
d['active_task'] = None
d['last_validation'] = 'passed' if rc == 0 else 'failed'
d['updated_at'] = datetime.datetime.now().astimezone().isoformat()
dump_json(d, p)
PY
    fi
    sync_state_from_plan "$issue"
    warn_if_knowledge_bloated "$issue"
  }

  case "$iso" in
  background)
    task_update "$tid" "status=running"
    local exitfile="$RUNTIME/tmp/issue-$issue/$tid.exit"
    local pidfile="$RUNTIME/tmp/issue-$issue/$tid.pid"
    # Every `log`/`err` call inside this subshell (should_continue_chain's
    # own messages, the codex unsandboxed-browser-check warning, the finish
    # summary, ...) would otherwise write to whatever stdout/stderr this
    # subshell inherited at fork time. `disown` only stops SIGHUP from
    # killing it when the launching shell exits - it does nothing to keep
    # that inherited stdout/stderr *writable* afterward. Under `set -e`, the
    # first `log`/`err` call after the launching shell is gone hits a broken
    # pipe and kills the whole chain right there, silently, often before a
    # multi-link chain even reaches its second link - defeating the entire
    # point of `disown` (surviving the launching shell going away, e.g. a
    # closed terminal). Redirect this subshell's own stdout/stderr to a real
    # file up front so it's immune to that regardless of what the launching
    # process does after this call returns.
    local driverlog="$logdir/background-driver-$tid.log"
    # `disown` (below) only stops SIGHUP from killing this job when the
    # launching shell exits - it does NOT move the job out of that shell's
    # process group. If anything sends a signal to the whole group (a
    # `killpg`-style teardown, e.g. a sandboxed session ending - not just the
    # terminal's stdout closing, which the driverlog redirect above already
    # covers), a merely-disowned same-pgid child dies with it, silently,
    # possibly mid-chain with no trace. `set -m` (job control) makes bash put
    # each background job in its OWN process group, so a group-wide signal
    # aimed at the launching shell's pgid no longer reaches this one. Toggled
    # off again immediately after capturing the pid - we don't want job
    # control's terminal/foreground-process-group semantics for the rest of
    # this script.
    set -m
    (
      # Forensic-only: this driver has been observed dying outright mid-chain
      # in real usage with zero trace (no exit sentinel, driverlog cut off
      # mid-write) - cause unconfirmed after ruling out the two leading
      # theories (harness reaping backgrounded children across tool-call
      # boundaries; the LLM CLI child killing its own shared process group on
      # exit) by direct reproduction attempts, neither of which reproduced a
      # death. These traps don't change behavior - a caught signal still logs
      # then exits with the conventional 128+signum code - they just make
      # sure that *if* it happens again and the cause is a catchable signal
      # (HUP/TERM/INT), this log has it instead of nothing. Can't catch
      # SIGKILL - if the driver vanishes with no DRIVER_SIGNAL or DRIVER_EXIT
      # line below it either way, that itself is the diagnostic: it means an
      # uncatchable kill or a full process disappearance, not a bash-level
      # crash.
      trap 'echo "$(date "+%Y-%m-%dT%H:%M:%S%z") DRIVER_SIGNAL HUP - driver subshell caught SIGHUP, exiting"; exit 129' HUP
      trap 'echo "$(date "+%Y-%m-%dT%H:%M:%S%z") DRIVER_SIGNAL TERM - driver subshell caught SIGTERM, exiting"; exit 143' TERM
      trap 'echo "$(date "+%Y-%m-%dT%H:%M:%S%z") DRIVER_SIGNAL INT - driver subshell caught SIGINT, exiting"; exit 130' INT
      trap 'echo "$(date "+%Y-%m-%dT%H:%M:%S%z") DRIVER_EXIT rc=$?"' EXIT
      local chain_tid="$tid" chain_logpath="$logpath" chain_session="$session_id"
      local rc iterations=0 max_iterations=200
      # This driver subshell's own, real, stable OS pid - same value the
      # parent captured via $! right after launching it. Not $BASHPID
      # (bash >= 4 only - macOS ships bash 3.2, where it's unset and blows
      # up under `set -u`). Not $$ either - inside a `()` subshell that
      # still reports the *invoking* shell's pid, not this one's. The
      # `$(exec sh -c 'echo $PPID')` idiom works on both: command
      # substitution's single-external-command optimization execs `sh`
      # in place of forking again, so its $PPID is this subshell's real pid.
      # Every link after the first is a fresh ledger row created only here,
      # inside the loop; without recording this pid on it too, reap_task's
      # "pid recorded but not alive -> mark failed" check (its only way to
      # notice the driver died mid-chain, since only link 1's row - $tid -
      # ever gets a pid from the parent-side `task_update "$tid" pid=$pid`
      # below) has nothing to check for links 2+, so a driver death after
      # link 1 leaves that link's row stuck on "running" forever and
      # maybe_resume_stalled_chain's `status != running` gate never trips.
      local driver_pid
      driver_pid="$(exec sh -c 'echo $PPID')"
      while :; do
        iterations=$((iterations + 1))
        run_link_background_body "$chain_tid" "$runner" "$chain_logpath" "$chain_session"
        rc=$?
        sync_state_from_plan "$issue"
        echo "$rc" > "$exitfile"
        if [ "$iterations" -ge "$max_iterations" ] || ! should_continue_chain "$chain_tid"; then
          break
        fi
        chain_tid="$(new_task_id)"
        chain_logpath="$logdir/execute-$(date '+%Y%m%d-%H%M%S')-${chain_tid:5:8}.log"
        write_all_runner "$chain_tid" "$chain_logpath"
        task_create "$chain_tid" "$issue" "execute" "$executor" "$model" "$mode" "$freshness" "$runner" "$chain_logpath" "running"
        task_update "$chain_tid" "pid=$driver_pid"
        if [ "$executor" = "claude" ]; then
          chain_session="$(gen_uuid)"
          task_update "$chain_tid" "session_id=$chain_session"
        fi
      done
      finalize_issue_state "$rc"
      local final_status
      final_status="$(task_field "$chain_tid" status)"
      log ""
      log "Task $chain_tid finished: $final_status"
      log ""
      print_job_summary "$issue"
    ) > "$driverlog" 2>&1 &
    local pid=$!
    set +m
    echo "$pid" > "$pidfile"
    disown "$pid" 2>/dev/null || true
    task_update "$tid" "pid=$pid"
    log "Task $tid started in background (pid $pid)."
    log "Background chain driver log (should_continue_chain/finish messages): $driverlog"
    [ "$mode" = "all" ] && log "Chained --all: will keep spawning fresh sessions automatically as long as each one passes and steps remain."
    log "Check with: ogre status --task $tid"
    if [ "$executor" = "codex" ]; then
      log "Codex session id will show up in that status once captured from its output."
    fi
    return
    ;;
  esac

  task_update "$tid" "status=running"
  local rc chain_tid="$tid" chain_logpath="$logpath" chain_session="$session_id"
  local iterations=0 max_iterations=200
  while :; do
    iterations=$((iterations + 1))
    run_link_foreground "$chain_tid" "$runner" "$chain_logpath" "$chain_session"
    rc=$?
    sync_state_from_plan "$issue"
    if [ "$iterations" -ge "$max_iterations" ] || ! should_continue_chain "$chain_tid"; then
      break
    fi
    log ""
    if [ "$(task_field "$chain_tid" status)" = "passed" ]; then
      log "Task $chain_tid passed and stopped early on its own context budget; steps remain - spawning a fresh session to continue."
    fi
    chain_tid="$(new_task_id)"
    chain_logpath="$logdir/execute-$(date '+%Y%m%d-%H%M%S')-${chain_tid:5:8}.log"
    write_all_runner "$chain_tid" "$chain_logpath"
    task_create "$chain_tid" "$issue" "execute" "$executor" "$model" "$mode" "$freshness" "$runner" "$chain_logpath" "running"
    if [ "$executor" = "claude" ]; then
      chain_session="$(gen_uuid)"
      task_update "$chain_tid" "session_id=$chain_session"
    fi
    log "Task id: $chain_tid"
  done
  tid="$chain_tid"

  # The ledger status (written by the subprocess's own task-complete call,
  # or by finalize_link_status as a fallback) is the real domain result -
  # not the last subprocess's raw exit code, which is usually 0 even on a
  # validation failure.
  local final_status
  final_status="$(task_field "$tid" status)"
  [ "$final_status" = "passed" ] && rc=0 || rc=1

  finalize_issue_state "$rc"
  if [ -n "$chain_session" ]; then
    case "$executor" in
      claude) log "Resume in Claude TUI: claude --resume $chain_session" ;;
      codex) log "Resume in Codex TUI: codex resume $chain_session" ;;
    esac
  fi
  log "Task $tid finished: $final_status"
  log ""
  print_job_summary "$issue"
  exit "$rc"
}

cmd_status() {
  ensure_runtime
  local target="" task_id="" list_tasks="false" job_id="" watch="false" interval="2"
  while [ $# -gt 0 ]; do
    case "$1" in
      --task) task_id="${2:-}"; shift 2 ;;
      --tasks) list_tasks="true"; shift ;;
      --job) job_id="${2:-}"; shift 2 ;;
      --watch) watch="true"; shift ;;
      --interval) interval="${2:-2}"; shift 2 ;;
      --*) err "Unknown option: $1"; exit 1 ;;
      *) target="$1"; shift ;;
    esac
  done

  if [ "$watch" = "true" ]; then
    trap 'exit 0' INT
    while true; do
      clear
      log "Ogre status (refreshing every ${interval}s, Ctrl-C to quit) - $(date '+%Y-%m-%d %H:%M:%S')"
      log ""
      _status_render "$target" "$task_id" "$list_tasks" "$job_id"
      sleep "$interval"
    done
    return
  fi

  _status_render "$target" "$task_id" "$list_tasks" "$job_id"
}

_status_render() {
  local target="$1" task_id="$2" list_tasks="$3" job_id="$4"

  if [ -n "$task_id" ]; then
    reap_task "$task_id"
    local rec
    rec="$(task_get "$task_id")"
    if [ "$rec" = "null" ]; then
      err "No task found with id $task_id"
      exit 1
    fi
    print_task_summary "$task_id"
    log ""
    log "Raw task record:"
    printf '%s\n' "$rec"
    return
  fi

  if [ -n "$job_id" ]; then
    target="$(resolve_issue_by_job_id "$job_id")"
    [ -n "$target" ] || { err "No issue found with job id $job_id"; exit 1; }
  fi

  if [ "$list_tasks" = "true" ]; then
    local issue_filter=""
    [ -n "$target" ] && issue_filter="$(slug_from_issue "$target")"
    log "Tasks${issue_filter:+ for issue $issue_filter}:"
    tasks_list "$issue_filter"
    return
  fi

  if [ -n "$target" ]; then
    local issue spath
    issue="$(slug_from_issue "$target")"
    ensure_state_from_plan "$issue" || true  # returns 1 when no plan to backfill; don't let set -e abort before the "No state found" branch
    spath="$(state_path "$issue")"
    if [ -f "$spath" ]; then
      reap_all_tasks
      sync_state_from_plan "$issue"
      maybe_resume_stalled_chain "$issue"
      seed_knowledge "$issue"
      print_job_summary "$issue"
      local kpath
      kpath="$(knowledge_path "$issue")"
      if [ -f "$kpath" ]; then
        log "Knowledge: $(wc -l < "$kpath" | tr -d ' ') lines  $kpath"
        warn_if_knowledge_bloated "$issue"
      fi
      log ""
      log "Raw state:"
      cat "$spath"
    else
      err "No state found for issue $issue"
      exit 1
    fi
  else
    log "Ogre runtime: $RUNTIME"
    log ""
    compact_tasks_ledger >/dev/null || true
    # Reaped up front (not just in the "Running/pending tasks" section below)
    # so a dead pid is already flipped to a terminal ledger status before
    # maybe_resume_stalled_chain looks at it per-issue in the loop next -
    # otherwise a genuinely-dead "running" task would look like it's still
    # in flight and get skipped instead of resumed.
    reap_all_tasks
    local spath fissue fstatus any="false"
    for spath in "$RUNTIME"/state/issue-*.json; do
      [ -f "$spath" ] || continue
      any="true"
      fissue="$(basename "$spath")"; fissue="${fissue#issue-}"; fissue="${fissue%.json}"
      # A completed/stopped job is terminal - its plan checklist won't change,
      # so re-deriving state from the plan (several python3 spawns) is wasted
      # work on every status call. One cheap status read decides; only live
      # jobs pay for a full re-sync. Keeps `ogre status` (no args) from getting
      # slower linearly as finished issues pile up.
      fstatus="$(json_field "$spath" status 2>/dev/null || true)"
      case "$fstatus" in
        completed|stopped) ;;
        *) sync_state_from_plan "$fissue"; maybe_resume_stalled_chain "$fissue" ;;
      esac
      print_job_summary "$fissue"
      log ""
    done
    [ "$any" = "true" ] || { log "No issues yet."; log ""; }

    log "Running/pending tasks:"
    reap_all_tasks
    local tids tid
    tids="$(python3 -c '
import json
try:
    tasks = json.load(open("'"$(tasks_path)"'"))
except Exception:
    tasks = []
for t in tasks:
    if t.get("status") in ("pending", "running"):
        print(t.get("id"))
')"
    if [ -n "$tids" ]; then
      while IFS= read -r tid; do
        [ -n "$tid" ] || continue
        print_task_summary "$tid"
        log ""
      done <<< "$tids"
    else
      log "None."
    fi
  fi
}

# Stop ALL tasks under one issue/job - used when stopping the whole feature.
stop_tasks_for_issue() {
  local issue="$1"
  python3 -c '
import json, sys
issue = sys.argv[1]
try:
    tasks = json.load(open(sys.argv[2]))
except Exception:
    tasks = []
for t in tasks:
    if str(t.get("issue")) == issue and t.get("status") in ("pending", "running"):
        print(t["id"], t.get("pid") or "")
' "$issue" "$(tasks_path)" | while read -r tid pid; do
    [ -n "$tid" ] || continue
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null || true
      log "Killed running task $tid (pid $pid)"
    fi
    task_update "$tid" "status=stopped"
  done
}

# Stop exactly ONE task, leaving its sibling tasks and the issue/job state
# untouched. For killing a single misbehaving background attempt without
# aborting the rest of the feature.
stop_one_task() {
  local tid="$1"
  local issue pid status
  { read -r issue; read -r status; read -r pid; } < <(task_fields "$tid" issue status pid)
  [ -n "$issue" ] || { err "No task found with id $tid"; exit 1; }
  if [ "$status" != "pending" ] && [ "$status" != "running" ]; then
    log "Task $tid is already $status. Nothing to stop."
    return
  fi
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
    kill "$pid" 2>/dev/null || true
    log "Killed running task $tid (pid $pid)"
  fi
  task_update "$tid" "status=stopped"
  log "Task $tid marked stopped. Issue $issue and its other tasks are untouched."
}

# Mark a task's ledger record passed/failed. This is the closing move for
# every execution path that ISN'T `ogre execute --run/--background` (those
# call task_update themselves): a human running the printed `codex exec`
# command by hand, a codex-plugin-cc /codex:rescue handoff, or the live
# Claude Code session executing the checklist item directly in-place. All
# three finish the same way now - without this, the ledger stays `pending`
# forever even though the real work is done (see execution-handoff.md).
cmd_task_complete() {
  ensure_runtime
  local tid="${1:-}" status="passed" exit_code="" notes=""
  [ -n "$tid" ] || { err "Usage: ogre task-complete <task-id> [--status passed|failed] [--exit-code N] [--notes \"...\"]"; exit 1; }
  shift || true
  while [ $# -gt 0 ]; do
    case "$1" in
      --status) status="${2:-passed}"; shift 2 ;;
      --exit-code) exit_code="${2:-}"; shift 2 ;;
      --notes) notes="${2:-}"; shift 2 ;;
      --*) err "Unknown option: $1"; exit 1 ;;
      *) err "Unknown argument: $1"; exit 1 ;;
    esac
  done
  case "$status" in
    passed|failed) ;;
    *) err "Invalid --status: $status (must be passed or failed)"; exit 1 ;;
  esac
  local rec
  rec="$(task_get "$tid")"
  [ "$rec" != "null" ] || { err "No task found with id $tid"; exit 1; }
  local -a updates=("status=$status")
  [ -n "$exit_code" ] && updates+=("exit_code=$exit_code")
  [ -n "$notes" ] && updates+=("notes=$notes")
  task_update "$tid" "${updates[@]}"
  local issue
  issue="$(task_field "$tid" issue)"
  sync_state_from_plan "$issue"
  log "Task $tid marked $status."
  print_task_summary "$tid"
}

cmd_stop() {
  ensure_runtime
  local target="" all="false" archive="false" delete="false" list="false" task_id="" job_id=""
  if [ $# -gt 0 ] && [[ ! "$1" =~ ^-- ]]; then
    target="$1"; shift
  fi
  while [ $# -gt 0 ]; do
    case "$1" in
      --all) all="true"; shift ;;
      --archive) archive="true"; shift ;;
      --delete) delete="true"; shift ;;
      --list) list="true"; shift ;;
      --task) task_id="${2:-}"; shift 2 ;;
      --job) job_id="${2:-}"; shift 2 ;;
      --current) shift ;;
      *) err "Unknown option: $1"; exit 1 ;;
    esac
  done

  # Stop exactly one task, sibling tasks and the job/issue untouched.
  if [ -n "$task_id" ]; then
    stop_one_task "$task_id"
    return
  fi

  # --job <job-id> is an alias for the issue it belongs to - stopping a job
  # cascades to every task under it (see stop_tasks_for_issue below).
  if [ -n "$job_id" ]; then
    target="$(resolve_issue_by_job_id "$job_id")"
    [ -n "$target" ] || { err "No issue found with job id $job_id"; exit 1; }
  fi

  if [ "$list" = "true" ]; then
    [ -n "$target" ] || { err "Missing issue for --list"; exit 1; }
    local list_issue
    list_issue="$(slug_from_issue "$target")"
    log "Ogre runtime files for issue $list_issue (nothing deleted):"
    list_issue_files "$list_issue"
    log ""
    log "To delete all at once: ogre stop $list_issue --delete"
    log "To delete one at a time: rm -rf <path> for whichever of the above the user picks"
    return
  fi

  if [ "$all" = "true" ]; then
    for spath in "$RUNTIME"/state/issue-*.json; do
      [ -f "$spath" ] || continue
      local fissue
      fissue="$(basename "$spath")"; fissue="${fissue#issue-}"; fissue="${fissue%.json}"
      stop_tasks_for_issue "$fissue"
      py_state "$spath" <<'PY' || true
import sys, datetime
p=sys.argv[1]
_lk = lock_state(p)
d=json.load(open(p))
d['status']='stopped'
d['active_task']=None
d['updated_at']=datetime.datetime.now().astimezone().isoformat()
dump_json(d, p)
PY
    done
    log "Marked all Ogre issues (jobs) as stopped. Any running tasks were signaled to stop. Runtime files kept."
    exit 0
  fi

  [ -n "$target" ] || { err "Missing issue for stop, or use --all"; exit 1; }
  local issue
  issue="$(slug_from_issue "$target")"

  if [ "$delete" = "true" ]; then
    printf 'Delete all Ogre data for issue %s? This will not revert code. Type yes: ' "$issue"
    read -r ans || true
    [ "$ans" = "yes" ] || { log "Cancelled."; exit 0; }
    delete_issue_data "$issue"
    exit 0
  fi

  if [ "$archive" = "true" ]; then
    archive_issue "$issue"
    exit 0
  fi

  local spath
  spath="$(state_path "$issue")"
  if [ -f "$spath" ]; then
    stop_tasks_for_issue "$issue"
    py_state "$spath" <<'PY' || true
import sys, datetime
p=sys.argv[1]
_lk = lock_state(p)
d=json.load(open(p))
d['status']='stopped'
d['active_task']=None
d['updated_at']=datetime.datetime.now().astimezone().isoformat()
dump_json(d, p)
PY
    log "Issue (job) $issue marked as stopped. Any running task was signaled to stop. Files kept. Code changes not reverted."
  else
    err "No state found for issue $issue"
    exit 1
  fi
}

# cmd_config - print every config.json key ogre actually reads: its dot path,
# current value (config.json if set, else the hardcoded fallback), and the
# CLI flag/command that overrides it for one invocation. Exists because
# config.json has no schema of its own and a key set in the wrong place
# (e.g. inside "defaults" vs top-level) silently does nothing.
# --reset backs up the current file to config.json.bak, then overwrites
# config.json with the fresh-install defaults (same as a brand-new project).
cmd_config() {
  local reset="false"
  while [ $# -gt 0 ]; do
    case "$1" in
      --reset) reset="true"; shift ;;
      *) err "Unknown option: $1"; exit 1 ;;
    esac
  done
  ensure_runtime
  local cfg="$RUNTIME/config.json"
  if [ "$reset" = "true" ]; then
    if [ -f "$cfg" ]; then
      cp -f "$cfg" "$cfg.bak"
      log "Backed up previous config to $cfg.bak"
    fi
    write_default_config "$cfg"
    log "Reset $cfg to fresh-install defaults."
    log ""
  fi
  log "Config file: $cfg"
  log ""
  python3 - "$cfg" <<'PY'
import json, os, sys

path = sys.argv[1]
d = {}
if os.path.isfile(path):
    try:
        d = json.load(open(path))
    except Exception:
        d = {}

def get(*keys):
    cur = d
    for k in keys:
        if not isinstance(cur, dict):
            return None
        cur = cur.get(k)
    return cur

roles = [
    ("planner",       "claude", "claude-sonnet-5", "--planner PROVIDER / --model MODEL (ogre feature)"),
    ("plan_reviewer", "claude", "claude-sonnet-5", "--reviewer PROVIDER / --model MODEL (ogre review-plan)"),
    ("executor",      "claude", "claude-sonnet-5", "--executor PROVIDER / --model MODEL (ogre execute)"),
    ("diff_reviewer", "claude", "claude-sonnet-5", None),
]

role_entries = []
for name, provider_fb, model_fb, override in roles:
    provider = get("defaults", name, "provider")
    model = get("defaults", name, "model")
    src = "config.json" if provider is not None or model is not None else "fallback"
    provider = provider if provider is not None else provider_fb
    model = model if model is not None else model_fb
    entry = '    "{}": {{ "provider": "{}", "model": "{}" }}'.format(name, provider, model)
    note = "{} | override: {}".format(src, override) if override else "{} | not read by any command yet".format(src)
    role_entries.append((entry, note))

browser_mcp = get("browser_mcp")
bm_src = "config.json" if "browser_mcp" in d else "fallback"
bm_shown = json.dumps(browser_mcp)
codex_unsandboxed = d.get("codex_unsandboxed_browser_check")
cu_src = "config.json" if "codex_unsandboxed_browser_check" in d else "fallback"
cu_shown = "true" if codex_unsandboxed else "false"

top_entries = [
    ('  "browser_mcp": {},'.format(bm_shown), "{} | override: --mcp-config PATH (ogre execute, [BROWSER-CHECK] steps)".format(bm_src)),
    ('  "codex_unsandboxed_browser_check": {}'.format(cu_shown), "{} | override: --codex-unsandboxed-browser-check (ogre execute, codex [BROWSER-CHECK] only)".format(cu_src)),
]

width = max(len(e) for e, _ in role_entries + top_entries)
print("{")
print('  "defaults": {')
for i, (entry, note) in enumerate(role_entries):
    comma = "," if i < len(role_entries) - 1 else ""
    print("{:<{w}}  # {}".format(entry + comma, note, w=width + 1))
print("  },")
for entry, note in top_entries:
    print("{:<{w}}  # {}".format(entry, note, w=width))
print("}")
PY
}

main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    init) cmd_init "$@" ;;
    feature) cmd_feature "$@" ;;
    add-blocker) cmd_add_blocker "$@" ;;
    review-plan) cmd_review_plan "$@" ;;
    execute) cmd_execute "$@" ;;
    status) cmd_status "$@" ;;
    task-list) cmd_task_list "$@" ;;
    task-complete) cmd_task_complete "$@" ;;
    stop) cmd_stop "$@" ;;
    config) cmd_config "$@" ;;
    -h|--help|help|"") usage ;;
    *) err "Unknown command: $cmd"; usage; exit 1 ;;
  esac
}

main "$@"
