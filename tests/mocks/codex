#!/usr/bin/env bash
# Mock `codex` CLI for `codex exec --skip-git-repo-check [-m MODEL] - < runner`.
# Mirrors a well-behaved real executor: reads the "Task id: `<tid>`" line the
# runner always contains, then calls `ogre task-complete` itself, same as
# the real handoff instructions require.
#   MOCK_CODEX_EXIT (default 0)       - the process's own exit code. Nonzero
#                                        simulates a crash *before* it could
#                                        call task-complete, so that call is
#                                        skipped (matching a real crashed CLI).
#   MOCK_CODEX_STATUS (default passed) - status passed to `ogre task-complete`
#   MOCK_CODEX_SKIP_COMPLETE=1        - simulate a subprocess that exits 0 but
#                                        forgot to call task-complete anyway
#   MOCK_CODEX_ARGS_FILE               - if set, the invocation's argv is
#                                         appended there (one line), so tests
#                                         can assert on flags ogre passed us.
#   MOCK_CODEX_NO_MCP=1                - `codex mcp list` reports no browser MCP
#                                        (default: reports a Playwright MCP, so
#                                         [BROWSER-CHECK] isolation is exercised)
#   MOCK_CODEX_WRITE_FILE               - if set, a placeholder is written
#                                        there before task-complete - stands
#                                        in for a real planner/reviewer
#                                        actually producing its output file
#                                        (plan/review path), which this mock
#                                        otherwise never touches.
set -euo pipefail
[ -n "${MOCK_CODEX_ARGS_FILE:-}" ] && printf '%s\n' "$*" >> "${MOCK_CODEX_ARGS_FILE}"
# `codex mcp list` - the browser-MCP detector for [BROWSER-CHECK] isolation.
# Reports a Playwright MCP by default; MOCK_CODEX_NO_MCP=1 reports none.
if [ "${1:-}" = "mcp" ]; then
  [ -z "${MOCK_CODEX_NO_MCP:-}" ] && echo "playwright  npx  @playwright/mcp@latest  enabled"
  exit 0
fi
runner="$(cat)" # capture stdin (the runner file) instead of draining it
tid="$(printf '%s\n' "$runner" | sed -n 's/.*Task id: `\(task-[^`]*\)`.*/\1/p' | head -n1)"
if [ -n "${MOCK_CODEX_WRITE_FILE:-}" ]; then
  mkdir -p "$(dirname "${MOCK_CODEX_WRITE_FILE}")"
  echo "# Mock output" > "${MOCK_CODEX_WRITE_FILE}"
fi
echo "session id: mock-codex-session-1234"
echo "Mock codex exec output"
if [ "${MOCK_CODEX_EXIT:-0}" = "0" ] && [ -z "${MOCK_CODEX_SKIP_COMPLETE:-}" ] && [ -n "${tid}" ]; then
  "${OGRE_BIN}" task-complete "${tid}" --status "${MOCK_CODEX_STATUS:-passed}"
fi
exit "${MOCK_CODEX_EXIT:-0}"
